# ============================================================
# WE MOVE IT. WE CLEAR IT. — Environment Variables
# Copy this file to .env.local for local dev
# NEVER commit .env.local or .env to git
# ============================================================

# ── APP ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://wmiwci-backend.vercel.app
APP_URL=http://localhost:3000

# Cookie domain (leave empty for localhost, set for production)
# Production: .moveitclearit.com    
COOKIE_DOMAIN=

s

# ── DATABASE ─────────────────────────────────────────────────
# Supabase / Neon / Railway / PlanetScale URL
# Example (Supabase): postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/moveit_dev
# Separate shadow DB for Prisma migrations
SHADOW_DATABASE_URL=postgresql://postgres:password@localhost:5432/moveit_shadow

# ── REDIS ────────────────────────────────────────────────────
# Upstash (recommended for Vercel): https://console.upstash.com
# Self-hosted: redis://localhost:6379
REDIS_URL="redis://default:REPLACE_ME@your-instance.upstash.io:6379"
# Upstash REST API (used by @upstash/ratelimit on edge)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# ── AUTH / JWT ───────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_EXPIRY=7d

# CSRF secret — generate with: openssl rand -hex 32
CSRF_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET

# ── OWNER CREDENTIALS (Diego) ────────────────────────────────
# Hash with: npx tsx scripts/hash-password.ts YOUR_PASSWORD
OWNER_EMAIL=diego@moveitclearit.com
OWNER_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# Manager credentials (Sebastian)
MANAGER_EMAIL=sebastian@moveitclearit.com
MANAGER_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# ── STRIPE ───────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook secret from: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Set to "true" ONLY for a deliberate test-mode launch on prod infra (Vercel
# forces NODE_ENV=production). Leave unset/false in real production with sk_live_.
STRIPE_ALLOW_TEST=false
# Booking fee amount in cents ($49.00)
STRIPE_BOOKING_FEE_CENTS=4900

# ── DISCORD ──────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=REPLACE_ME
# Application ID from Developer Portal → General Information
DISCORD_APPLICATION_ID=REPLACE_ME
# Public Key from Developer Portal → General Information
DISCORD_PUBLIC_KEY=REPLACE_ME
# Your server (guild) ID (right-click server → Copy Server ID)
DISCORD_GUILD_ID=REPLACE_ME

# Channel IDs (right-click channel → Copy Channel ID after enabling Developer Mode)
DISCORD_CHANNEL_JOBS=REPLACE_ME
DISCORD_CHANNEL_PAPERWORK=REPLACE_ME
DISCORD_CHANNEL_PHOTOS=REPLACE_ME
DISCORD_CHANNEL_PAYMENTS=REPLACE_ME
DISCORD_CHANNEL_RECEIPTS=REPLACE_ME
DISCORD_CHANNEL_SCHEDULING=REPLACE_ME
DISCORD_CHANNEL_OPERATIONS=REPLACE_ME
DISCORD_CHANNEL_NEWS=REPLACE_ME
DISCORD_CHANNEL_BOT_LOGS=REPLACE_ME

# Staff Discord user IDs (right-click user → Copy User ID)
DISCORD_USER_DIEGO=REPLACE_ME
DISCORD_USER_SEBASTIAN=REPLACE_ME

# ── OWNER PERMISSIONS (who can approve/deny/manage bookings from Discord) ──────
# A user is an authorized owner when EITHER of these is true inside DISCORD_GUILD_ID:
#   • their user ID is in this comma-separated allowlist, OR
#   • they hold the owner role below.
# Add a new manager by appending their user ID here (or granting them the role) —
# no code change needed. Legacy DISCORD_USER_DIEGO / DISCORD_USER_SEBASTIAN above
# are also honored as owners for backward compatibility.
# Example: DISCORD_OWNER_USER_IDS=123456789012345678,901897768937869332
DISCORD_OWNER_USER_IDS=REPLACE_ME
# The Discord role that grants owner powers (right-click role → Copy Role ID).
# Anyone with this role can perform every owner action. Leave blank to gate on
# user IDs only.
DISCORD_OWNER_ROLE_ID=REPLACE_ME

# ── RESEND (Email) ────────────────────────────────────────────
# Get key at https://resend.com
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=Move It Clear It <hello@moveitclearit.com>
EMAIL_REPLY_TO=hello@moveitclearit.com

# ── CLOUDINARY (File Storage) ─────────────────────────────────
# Get from https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=REPLACE_ME
CLOUDINARY_API_KEY=REPLACE_ME
CLOUDINARY_API_SECRET=REPLACE_ME

# ── TWILIO (SMS) — WIRED, INACTIVE until keys added ──────────
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=+1REPLACE_ME
# Set to "true" to activate SMS sending
TWILIO_ENABLED=false

# ── CLOUDFLARE TURNSTILE — WIRED, INACTIVE ───────────────────
# Get from https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=REPLACE_ME
TURNSTILE_SECRET_KEY=REPLACE_ME
# Set to "true" to enforce CAPTCHA
TURNSTILE_ENABLED=false

# ── SENTRY — WIRED, INACTIVE ─────────────────────────────────
# Get from https://sentry.io
SENTRY_DSN=REPLACE_ME
NEXT_PUBLIC_SENTRY_DSN=REPLACE_ME
# Set to "true" to activate Sentry
SENTRY_ENABLED=false

# ── SCHEDULING ────────────────────────────────────────────────
TIMEZONE=America/New_York
MAX_JOBS_PER_DAY=3
TRAVEL_BUFFER_MINUTES=60
MIN_BOOKING_NOTICE_HOURS=24

# ── SECURITY ──────────────────────────────────────────────────
# Max booking attempts per IP per hour
RATE_LIMIT_BOOKING=5
# Max login attempts per IP per 15 minutes
RATE_LIMIT_LOGIN=10

# ── MOVING SERVICE AGREEMENT ─────────────────────────────────
# Version stamp stored on every booking for legal traceability.
# Bump when you change the agreement text in src/lib/agreement.ts.
# Optional — defaults to "v1-2026-05" if unset.
AGREEMENT_VERSION=v1-2026-05

# ── MARKETING AUTOMATION (external tool) — WIRED, INACTIVE ────
# Used by src/lib/marketing.ts to enroll paying customers into your
# email/CRM tool (Mailchimp/HubSpot/Klaviyo/etc.). Until BOTH are set,
# the marketing step no-ops safely (logs "skipping").
MARKETING_API_KEY=REPLACE_ME
MARKETING_LIST_ID=REPLACE_ME

# ── LINKS ─────────────────────────────────────────────────────
# URL of the marketing site (for cancel redirect, etc.)
MARKETING_SITE_URL=https://moveitclearit.com

# Bull Board UI — run as standalone Express app on internal port 3001
# Leave empty to disable redirect from /api/admin/queues/bull-board
BULL_BOARD_URL=

# ── EMAIL OUTBOX (src/outbox) ────────────────────────────────
# Master switch. When "true", payment/approve/reschedule trigger points emit
# events to the outbox (which sends the email) and the email at that point is
# skipped — never both. Default OFF = behavior unchanged. Run the migration
# (npx prisma migrate deploy) BEFORE turning this on.

# ── EMAIL LIFECYCLE (owner spec 2026-07-20) ──────────────────────────────
# Signing secret for unsubscribe / preference links. If unset it is DERIVED
# from RESEND_API_KEY; in production with a placeholder Resend key, signing
# THROWS rather than sign links with a known dev secret. Set a real value.
EMAIL_TOKEN_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET

# Resend webhook signing secret (Svix). WITHOUT THIS the webhook returns 503
# and bounces/complaints are NEVER processed — promotional sending is unsafe.
# Resend dashboard -> Webhooks -> endpoint {APP_URL}/api/email/webhook
RESEND_WEBHOOK_SECRET=whsec_REPLACE_ME

# Shared secret for /api/email/suppression, so Leadtracking (SendGrid) and this
# system honour ONE opt-out list. Unset = the endpoint is DISABLED (503), not open.
EMAIL_SUPPRESSION_API_KEY=REPLACE_ME

# Physical postal address on PROMOTIONAL mail. CAN-SPAM requires it. Nothing
# hard-codes an address, so promotional sending must not be enabled until this
# is set and passed by the senders.
BUSINESS_POSTAL_ADDRESS=REPLACE_ME

# Lifecycle journeys. OFF unless explicitly true. Disable one at a time with
# EMAIL_JOURNEY_<NAME>_DISABLED=true (ABANDONED | REMINDERS | QUOTE).
EMAIL_JOURNEYS_ENABLED=false

# Referral programme. The 10-rule eligibility gate also requires a completed
# Stripe payment + a durable AuditLog(RECEIPT_SENT) event.
REFERRAL_PROGRAM_ENABLED=false
REFERRAL_REQUIRE_STRIPE=true
REFERRAL_URL=https://www.moveitclearit.com/refer
REFERRAL_CODE=REFER15

# Frequency caps + quiet hours. PROMOTIONAL mail only — transactional booking
# mail is exempt by design (a receipt must arrive when the event happens).
EMAIL_CAP_PER_DAY=1
EMAIL_CAP_PER_WEEK=3
EMAIL_CAP_PER_MONTH=6
EMAIL_QUIET_END_HOUR=8
EMAIL_QUIET_START_HOUR=21
EMAIL_TRANSACTIONAL_GAP_MINUTES=60

# Post-move follow-ups (review / repeat / referral).
MARKETING_FOLLOWUPS_ENABLED=false
GOOGLE_REVIEW_URL=REPLACE_ME

# Hosted email images (hero + icons).
EMAIL_ASSET_BASE_URL=https://moveitclearit.com/email

OUTBOX_ENABLED=false
# Log emails instead of sending them (test the pipeline without real mail).
OUTBOX_EMAIL_DRYRUN=false
# Worker tuning (run: tsx src/outbox/workers/emailWorker.ts)
OUTBOX_POLL_MS=3000
OUTBOX_BATCH=20
# A job stuck in 'processing' longer than this (crashed worker) is requeued.
OUTBOX_STALE_PROCESSING_MS=300000
# Send the optional NEW_DATE_PICKED email (default: just re-post the Discord card)
OUTBOX_SEND_DATE_PICKED=false

# ── CONTROLLED TEST PAYMENTS (staging only; owner spec 2026-07-15) ──────────────
# OFF by default. When 'true', the OWNER-only POST /api/admin/test-booking can
# create a flagged internal-test booking with a small controlled deposit (below)
# instead of the real $49 — for verifying authorize/approve/capture/refund WITHOUT
# touching public pricing. Never set this in normal production. Unset to disable.
ALLOW_TEST_PAYMENTS=false
# Controlled test amount in CENTS (default 100 = $1). Clamped to [50, 4900].
TEST_PAYMENT_AMOUNT_CENTS=100
