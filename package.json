{
  "name": "moveit-clearit-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "host:dev": "tsx --watch src/worker-host.ts",
    "host:start": "tsx src/worker-host.ts",
    "workers:dev": "tsx --watch src/workers/index.ts",
    "workers:start": "tsx src/workers/index.ts",
    "outbox:dev": "tsx --watch src/outbox/workers/emailWorker.ts",
    "outbox:start": "tsx src/outbox/workers/emailWorker.ts",
    "bot:dev": "tsx --watch src/bot/index.ts",
    "bot:start": "tsx src/bot/index.ts",
    "bot:register": "tsx src/bot/register-commands.ts",
    "backup": "bash scripts/backup-db.sh",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/__tests__/booking-display.test.ts src/lib/__tests__/discount-decision.test.ts src/lib/__tests__/booking-access.test.ts src/lib/__tests__/booking-completeness.test.ts src/lib/__tests__/booking-contract.test.ts src/lib/__tests__/pricing.test.ts src/lib/__tests__/booking-projections.test.ts src/lib/__tests__/address.test.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "register-commands": "tsx src/bot/register-commands.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@bull-board/api": "^5.19.2",
    "@bull-board/express": "^5.19.2",
    "@cloudinary/url-gen": "^1.21.0",
    "@prisma/client": "^5.16.0",
    "@react-email/components": "^0.0.22",
    "@react-email/render": "^0.0.17",
    "@upstash/ratelimit": "^2.0.1",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cloudinary": "^2.4.0",
    "cuid": "^2.1.8",
    "discord.js": "^14.15.3",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "next": "14.2.35",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.4.0",
    "stripe": "^16.2.0",
    "tsx": "^4.16.2",
    "tweetnacl": "^1.0.3",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "gif-encoder-2": "^1.0.5",
    "postcss": "^8.4.39",
    "prisma": "^5.16.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  }
}
