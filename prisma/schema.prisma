// ============================================================
// PRISMA SCHEMA — Move It Clear It
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CREW
}

enum BookingStatus {
