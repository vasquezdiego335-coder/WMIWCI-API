// ── Phase 1 labor system (owner spec 2026-07-20) ─────────────────────────────
//    JobCrew is THE canonical financial labor record for a customer move; see
//    docs/admin/discord-crew-integration.md. These enums split the one legacy
//    CrewPayStatus into the three dimensions the workflow actually has: whether
//    someone is ON the job (assignment), whether the money is AGREED (approval),
//    and whether it has MOVED (payment). CrewPayStatus is retained and kept in
//    sync so existing readers keep working.

enum CrewWorkerType {
  OWNER // Diego / Sebastian — may work unpaid; carries an economic labor value
  EMPLOYEE
  CONTRACTOR
  TEMP_HELPER
}

enum CrewRole {
  CREW_MEMBER
  CREW_LEADER
  DRIVER
  HELPER
  OWNER_OPERATOR
  OTHER
}

enum CrewAssignmentStatus {
  INVITED
  OFFERED
  ACCEPTED
  DECLINED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ── Stage 5 crew management (owner spec 2026-07-21) ──────────────────────────

/// OPERATIONAL availability of a worker. Deliberately separate from `role`
/// (auth), `workerType` (pay) and the legacy `active` boolean. A person who is
/// ON_LEAVE is still an employee; a SUSPENDED person keeps every historical row.
enum WorkerStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  UNAVAILABLE
  SUSPENDED
}

/// The closed skill vocabulary. Stored as a native array on User and on a
/// job's staffing requirement.
enum CrewSkill {
  PACKING
  FURNITURE_PROTECTION
  ASSEMBLY
  HEAVY_ITEMS
  STAIR_CARRY
  DRIVING
  LEAD
  LOADING
  UNLOADING
}

/// A date-specific availability exception. Precedence order is encoded in
/// availability-engine.ts, not here.
enum AvailabilityExceptionKind {
  ADMIN_BLOCK // administrative hard-unavailable — highest precedence
  UNAVAILABLE_FULL // worker unavailable all day
  UNAVAILABLE_PARTIAL // unavailable for a window
  AVAILABLE_OVERRIDE // explicitly available despite recurring rules
  VACATION
  LEAVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

/// How the recorded time got there — an audit signal, not a workflow state.
enum TimeEntrySource {
  CLOCK // crew tapped clock in / out
  MANUAL // owner typed the hours
  IMPORTED
  OWNER_OVERRIDE // owner corrected a submitted record
  DISCORD_WORKFLOW
}

/// Is the money AGREED? Separate from whether it has been paid.
enum LaborApprovalStatus {
  DRAFT // assignment exists, hours not submitted
  SUBMITTED // hours submitted for review
  NEEDS_REVIEW // flagged by validation
  APPROVED // owner agreed the amount — a real cost and a liability
  REJECTED // not a cost at all
}

/// Has the money MOVED? Independent of approval.
enum LaborPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  VOIDED
}

/// How this assignment is priced. The applicable rate is SNAPSHOT onto the
/// assignment; a later profile change must never rewrite a historical move.
enum LaborPayModel {
  HOURLY
  FLAT
  DAY_RATE
  UNPAID_OWNER // owner works, no cash changes hands; economic value still recorded
  ZERO_CONFIRMED // explicitly confirmed $0 labor (owner + reason required)
  CUSTOM // owner-approved amount no formula produces
}

// ── Phase 2 financial closeout (owner spec 2026-07-20) ───────────────────────
//    Turning a completed move into a DURABLE financial record. The governing
//    rule: a finalized closeout must never change because a setting changed
//    later — see FinancialSnapshot.

enum CloseoutStatus {
  NOT_STARTED
  IN_PROGRESS
  MISSING_INFORMATION
  READY_FOR_REVIEW
  READY_TO_FINALIZE
  FINALIZED
  REOPENED
}

/// How company overhead is charged to a move. The method AND the rate are
/// snapshotted at finalization so changing policy never rewrites history.
enum OverheadMethod {
  NONE
  PER_MOVE // fixed cents per completed move
  PCT_REVENUE // percentage of net collected revenue
  PER_LABOR_HOUR // cents per approved crew hour
  MONTHLY_POOL // monthly pool / eligible completed moves
  MANUAL // owner-entered amount + reason
}

enum ReserveKind {
  TAX
  GENERAL
  EMERGENCY
  TRUCK_FUND
  EQUIPMENT_FUND
  LICENSING_FUND
  INSURANCE_FUND
  MARKETING_FUND
  GROWTH_FUND
  RETAINED_EARNINGS
  OTHER
}

/// How an owner split was decided. Recorded so a distribution can always be
/// explained months later.
enum SplitMethod {
  EQUAL
  OWNERSHIP_PERCENT
  LABOR_FIRST
  CUSTOM
}

enum DistributionStatus {
  PLANNED
  APPROVED
  PARTIALLY_PAID
  PAID
  VOIDED
}

/// Where the truck came from. NOT_REQUIRED and CUSTOMER_PROVIDED must be chosen
/// EXPLICITLY — a missing truck cost is never assumed to be zero.
enum TruckSource {
  CUSTOMER_PROVIDED
  COMPANY_OWNED
  RENTAL
  THIRD_PARTY
  NOT_REQUIRED
}

/// Is travel time paid, and how? Per assignment, because it varies by worker.
enum TravelPayPolicy {
  UNPAID // travel recorded for analysis only
  REGULAR // travel minutes are paid at the regular rate (added to paid time)
  SEPARATE_RATE // travel paid at its own snapshot rate
}

// ── MODELS ────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(CREW)
  discordId    String?  @map("discord_id")
  phone        String?
  active       Boolean  @default(true)

  // ── HR / payroll (admin OS, owner spec 2026-07-13) — all nullable ──
  //    payRate is the DEFAULT cents/hour; a JobCrew row can override it per job.
  payRate               Int?           @map("pay_rate") // cents per hour
  // Phase 1: the CURRENT profile defaults. These seed a JobCrew rate SNAPSHOT at
  // assignment time and are never read again for that assignment — changing a
  // rate here must not alter what a past move cost.
  defaultFlatRateCents  Int?           @map("default_flat_rate_cents")
  workerType            CrewWorkerType @default(EMPLOYEE) @map("worker_type")
  preferredRole         String?        @map("preferred_role")
  emergencyContact      String?        @map("emergency_contact")
  emergencyContactPhone String?        @map("emergency_contact_phone")
  reliabilityRating     Int?           @map("reliability_rating") // 1-5
  performanceNotes      String?        @map("performance_notes")

  // ── Stage 4 labor-rate configuration (owner spec 2026-07-21) ──
  //    What the OWNER types in through /admin/staff. EVERY rate is nullable on
  //    purpose: an unset rate is UNKNOWN, never $0, and it keeps
  //    LABOR_MISSING_RATE a HARD closeout blocker until a human supplies it.
  //
  //    Changing anything here must never alter a past move. JobCrew holds the
  //    frozen snapshot taken at assignment time and is never re-read from this
  //    profile — see labor-calc.buildRateSnapshot.
  /// What THIS owner's hour is worth if it had to be hired out. Drives ECONOMIC
  /// profit only — never cash, never a payable, and entirely separate from the
  /// 30% owner profit allocations. Null = not configured.
  ownerEconomicRateCents Int?           @map("owner_economic_rate_cents")
  /// How this person is paid by default when they ARE paid. Null = unset.
  defaultPayModel        LaborPayModel? @map("default_pay_model")
  /// The date the current rate takes effect. Recorded, not enforced — it exists
  /// so a rate change can be explained later.
  rateEffectiveOn        DateTime?      @map("rate_effective_on")
  rateNotes              String?        @map("rate_notes")
  rateUpdatedById        String?        @map("rate_updated_by_id")
  rateUpdatedAt          DateTime?      @map("rate_updated_at")
  /// Eligibility flags used when staffing a move. Not money.
  canDrive               Boolean        @default(false) @map("can_drive")
  canLeadCrew            Boolean        @default(false) @map("can_lead_crew")

  // ── Stage 5 crew management (owner spec 2026-07-21) ──
  //    workerStatus is the OPERATIONAL availability of a person, kept separate
  //    from `role` (auth), `workerType` (how they're paid) and `active` (the
  //    legacy on/off). A deactivated worker keeps every historical row.
  workerStatus            WorkerStatus @default(ACTIVE) @map("worker_status")
  /// Operational capabilities. A native enum array — additive and defaulted.
  skills                  CrewSkill[]  @default([]) @map("skills")
  /// Driver's-license expiry; a past date makes the person an ineligible driver.
  licenseExpiresAt        DateTime?    @map("license_expires_at")
  /// May drive a customer-rented truck (some rental agreements restrict this).
  canDriveCustomerVehicle Boolean      @default(false) @map("can_drive_customer_vehicle")
  startDate               DateTime?    @map("start_date")
  deactivatedAt           DateTime?    @map("deactivated_at")
  deactivationReason      String?      @map("deactivation_reason")
  createdById             String?      @map("created_by_id")
  updatedById             String?      @map("updated_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  availability        Availability[]
  assignedJobs        JobCrew[]
  auditLogs           AuditLog[]
  availabilityRules   AvailabilityRule[]
  availabilityExceptions AvailabilityException[]

  @@map("users")
}

model Customer {
  id              String  @id @default(cuid())
  email           String  @unique
  name            String
  phone           String
  isFirstTime     Boolean @default(true) @map("is_first_time")
  // Preferred language for all customer-facing email + SMS ("en" | "es").
  // Captured from the marketing site's EN/ES toggle at booking time.
  locale          String  @default("en")
  // TCPA marketing opt-out — set true when a customer texts STOP (inbound SMS
  // webhook). Phase-3 follow-ups are suppressed for opted-out customers. The 4
  // transactional booking messages are unaffected (they're not marketing).
  marketingOptOut Boolean @default(false) @map("marketing_opt_out")

  // ── Extended contact (admin operations, owner spec 2026-07-12) — all nullable ──
  preferredName         String? @map("preferred_name")
  secondaryPhone        String? @map("secondary_phone")
  emergencyContact      String? @map("emergency_contact")
  emergencyContactPhone String? @map("emergency_contact_phone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  bookings Booking[]

  @@map("customers")
}

model Booking {
  id               String        @id @default(cuid())
  displayId        String        @unique @default(cuid()) @map("display_id") // mirrors bookingReference for back-compat
  // Public, human-friendly booking reference (WMIC-####). Backed by an atomic
  // Postgres sequence (booking_reference_seq) so concurrent inserts can never
  // collide; assigned once at creation and never changed. The internal cuid `id`
  // stays the private key used for all relationships/joins/webhooks. Nullable so
  // historical/internal-test rows may stay unreferenced. See src/lib/booking-reference.ts.
  bookingReference String?       @unique @map("booking_reference")
  status           BookingStatus @default(DRAFT)
  outboxState      BookingState? @map("outbox_state") // src/outbox email state machine (additive, nullable)
  // Owner checkout tests (mirrors Payment.isInternalTest). EXCLUDED from every
  // operational count + revenue report. Flagged by scripts/flag-test-bookings.ts.
  isInternalTest   Boolean       @default(false) @map("is_internal_test")
  customerId       String        @map("customer_id")

  // Location
  originAddress String  @map("origin_address")
  destAddress   String  @map("dest_address")
  originFloor   Int?    @map("origin_floor")
  destFloor     Int?    @map("dest_floor")
  hasElevator   Boolean @default(false) @map("has_elevator")

  // Items
  itemsDescription String? @map("items_description")
  estimatedHours   Float?  @map("estimated_hours")

  // Schedule
  requestedDate  DateTime? @map("requested_date")
  confirmedDate  DateTime? @map("confirmed_date")
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")

  // Reschedule tracking — the $49 hold stays attached across reschedules.
  previousRequestedDate DateTime? @map("previous_requested_date")
  rescheduleCount       Int       @default(0) @map("reschedule_count")
  rescheduledAt         DateTime? @map("rescheduled_at")

  // Pricing
  depositAmount          Int     @default(4900) @map("deposit_amount") // cents — $49 booking fee
  depositPaid            Boolean @default(false) @map("deposit_paid")
  truckAddonDueOnMoveDay Boolean @default(false) @map("truck_addon_due_on_move_day")
  truckAddonAmount       Int     @default(0) @map("truck_addon_amount") // cents
  baseRate               Float?  @map("base_rate")
  totalEstimate          Float?  @map("total_estimate")
  finalAmount            Float?  @map("final_amount")

  // ── Service area / travel fee (server-computed; see src/lib/service-area.ts) ──
  //    travelFee is charged on move day like the truck add-on — never in Stripe.
  serviceAreaZone             ServiceAreaZone? @map("service_area_zone")
  travelFee                   Int              @default(0) @map("travel_fee") // cents; 0 = none
  travelFeeDueOnMoveDay       Boolean          @default(false) @map("travel_fee_due_on_move_day")
  manualReviewRequired        Boolean          @default(false) @map("manual_review_required")
  serviceAreaMessage          String?          @map("service_area_message")
  distanceFromWestOrangeMiles Float?           @map("distance_from_west_orange_miles")
  estimatedDriveTimeMinutes   Int?             @map("estimated_drive_time_minutes")
  addressEvaluation           Json?            @map("address_evaluation")

  // Discount
  discountCode         String?       @map("discount_code")
  discountType         DiscountType? @map("discount_type")
  discountPercent      Float?        @map("discount_percent")
  discountApprovedById String?       @map("discount_approved_by_id")

  // Stripe
  stripeCheckoutId      String? @unique @map("stripe_checkout_id")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")

  // Discord
  discordJobChannelId       String? @map("discord_job_channel_id")
  discordPaperworkChannelId String? @map("discord_paperwork_channel_id")
  discordPhotosChannelId    String? @map("discord_photos_channel_id")
  discordApprovalMessageId  String? @map("discord_approval_message_id")

  // Self-service token for customer portal
  customerToken       String   @unique @default(cuid()) @map("customer_token")
  customerTokenExpiry DateTime @map("customer_token_expiry")

  // Notes
  internalNotes String? @map("internal_notes")
  customerNotes String? @map("customer_notes")

  // ── Structured access details (owner spec 2026-07-12) ────────────────────
  //    Backward-compatible: EVERY field is nullable, so existing bookings read
  //    as null. Pickup (origin*) and drop-off (dest*) are kept separate.
  //    originFloor/destFloor above are REUSED for the floor number (no dupes).
  //    SENSITIVE: origin/destAccessCode are gate/lockbox/buzzer codes — surfaced
  //    ONLY in the owner-gated Discord "View Full Booking" + authorized admin
  //    views; they are omitted from the customer portal API and never written to
  //    itemsDescription (which feeds public emails + the customer summary).
  originUnit        String?  @map("origin_unit") // apartment / unit #
  destUnit          String?  @map("dest_unit")
  originHasElevator Boolean? @map("origin_has_elevator") // per-location elevator
  destHasElevator   Boolean? @map("dest_has_elevator")
  originStairCount  Int?     @map("origin_stair_count") // flights / approx count
  destStairCount    Int?     @map("dest_stair_count")
  originAccessNotes String?  @map("origin_access_notes") // parking/loading + building access (non-sensitive)
  destAccessNotes   String?  @map("dest_access_notes")
  originAccessCode  String?  @map("origin_access_code") // SENSITIVE
  destAccessCode    String?  @map("dest_access_code") // SENSITIVE

  // Customer-provided truck details — informational only. The $50 pickup/return
  // FEE stays governed by truckAddonDueOnMoveDay/truckAddonAmount (no new fee).
  truckProvider             String? @map("truck_provider") // customer / U-Haul / Penske / WMIWCI
  truckSize                 String? @map("truck_size") // 10ft / 15ft / 26ft …
  truckReservationStatus    String? @map("truck_reservation_status") // reserved / not-yet / n/a
  truckPickupLocation       String? @map("truck_pickup_location")
  truckReturnResponsibility String? @map("truck_return_responsibility")

  equipmentNeeds   String? @map("equipment_needs") // dollies/straps/piano board (informational)
  crewInstructions String? @map("crew_instructions") // customer's move-day instructions for the crew

  // ── Verified structured address (Phase 2, owner spec 2026-07-12). Written by
  //    SERVER-side Google Address Validation only — client-claimed components are
  //    never persisted. Nullable: legacy bookings read as NULL and display the
  //    originAddress/destAddress strings. verification_status:
  //    verified | partial | unverified | skipped (no provider key/timeout)
  originStreetNumber     String? @map("origin_street_number")
  originRoute            String? @map("origin_route")
  originCity             String? @map("origin_city")
  originCounty           String? @map("origin_county")
  originState            String? @map("origin_state")
  originZip              String? @map("origin_zip")
  originCountry          String? @map("origin_country")
  originFormatted        String? @map("origin_formatted_address")
  originLat              Float?  @map("origin_lat")
  originLng              Float?  @map("origin_lng")
  originPlaceId          String? @map("origin_place_id")
  originVerification     String? @map("origin_verification_status")
  originValidationReason String? @map("origin_validation_reason")
  destStreetNumber       String? @map("dest_street_number")
  destRoute              String? @map("dest_route")
  destCity               String? @map("dest_city")
  destCounty             String? @map("dest_county")
  destState              String? @map("dest_state")
  destZip                String? @map("dest_zip")
  destCountry            String? @map("dest_country")
  destFormatted          String? @map("dest_formatted_address")
  destLat                Float?  @map("dest_lat")
  destLng                Float?  @map("dest_lng")
  destPlaceId            String? @map("dest_place_id")
  destVerification       String? @map("dest_verification_status")
  destValidationReason   String? @map("dest_validation_reason")

  // ── Move details (owner spec 2026-07-12) — structured inventory of the job.
  //    Nullable; collected on the booking form (future) or entered by staff. ──
  bedrooms           Int?     @map("bedrooms")
  estimatedCubicFeet Int?     @map("estimated_cubic_feet")
  estimatedWeightLbs Int?     @map("estimated_weight_lbs")
  numBoxes           Int?     @map("num_boxes")
  needsPacking       Boolean? @map("needs_packing")
  needsUnpacking     Boolean? @map("needs_unpacking")
  needsAssembly      Boolean? @map("needs_assembly")
  needsDisassembly   Boolean? @map("needs_disassembly")
  needsStorage       Boolean? @map("needs_storage")
  hasPiano           Boolean? @map("has_piano")
  hasSafe            Boolean? @map("has_safe")
  hasPoolTable       Boolean? @map("has_pool_table")
  hasAppliances      Boolean? @map("has_appliances")
  specialtyItems     String?  @map("specialty_items")

  // ── Truck operations (extends the customer-provided truck fields above) ──
  truckReservationNumber String? @map("truck_reservation_number")
  truckPickupTime        String? @map("truck_pickup_time")
  truckReturnAddress     String? @map("truck_return_address")
  driverName             String? @map("driver_name")
  driverPhone            String? @map("driver_phone")
  driverLicense          String? @map("driver_license")
  truckFuelPolicy        String? @map("truck_fuel_policy")
  additionalTruckFees    Int?    @map("additional_truck_fees") // cents

  // ── Itemized fees (cents) — base/travel/truck add-on/discount live above.
  //    Nullable so existing bookings stay null; a professional invoice reads them. ──
  stairFee       Int? @map("stair_fee")
  longCarryFee   Int? @map("long_carry_fee")
  heavyItemFee   Int? @map("heavy_item_fee")
  packingFee     Int? @map("packing_fee")
  assemblyFee    Int? @map("assembly_fee")
  disassemblyFee Int? @map("disassembly_fee")
  taxAmount      Int? @map("tax_amount")
  processingFee  Int? @map("processing_fee")

  // ── Late Arrival & Delay Policy (owner spec 2026-07-12) ───────────────────
  //    Complimentary 30-min grace from crew arrival, then $50 per additional
  //    30-min block. The math lives in src/lib/waiting-time.ts (single source).
  //    The fee is COLLECTED ON MOVE DAY like the travel fee / truck add-on — it
  //    is NEVER added to the $49 Stripe deposit and never auto-charged.
  //    Crew log these four timestamps by tapping the Discord job-card buttons.
  crewArrivedAt       DateTime? @map("crew_arrived_at")
  customerReadyAt     DateTime? @map("customer_ready_at")
  waitingStartedAt    DateTime? @map("waiting_started_at")
  waitingEndedAt      DateTime? @map("waiting_ended_at")
  //    waitingMinutes / waitingFee are DERIVED (waiting-time.ts) and persisted
  //    at waiting-end so the receipt/report is a stable record. waitingFeeOverride
  //    (cents, nullable) lets staff hand-set the charge; waived zeroes it out.
  waitingMinutes      Int?      @map("waiting_minutes")
  waitingFee          Int?      @map("waiting_fee") // cents; derived unless overridden
  waitingFeeOverride  Int?      @map("waiting_fee_override") // cents; staff manual override
  waitingFeeWaived    Boolean   @default(false) @map("waiting_fee_waived")
  waitingWaiverReason String?   @map("waiting_waiver_reason")
  waitingFeeCollected Boolean   @default(false) @map("waiting_fee_collected")

  // ── Internal operations (staff-entered via the admin edit panel) ──
  arrivalWindow      String? @map("arrival_window") // e.g. "8:00–10:00 AM"
  assignedDispatcher String? @map("assigned_dispatcher")
  dispatcherNotes    String? @map("dispatcher_notes")
  crewNotes          String? @map("crew_notes")
  driverNotes        String? @map("driver_notes")
  officeNotes        String? @map("office_notes")
  schedulingNotes    String? @map("scheduling_notes")
  travelNotes        String? @map("travel_notes")
  problemFlags       String? @map("problem_flags")
  outstandingTasks   String? @map("outstanding_tasks")
  completionProgress Int?    @map("completion_progress") // 0–100

  // Moving Service Agreement (legal acceptance record)
  agreementAccepted   Boolean   @default(false) @map("agreement_accepted")
  agreementVersion    String?   @map("agreement_version")
  agreementAcceptedAt DateTime? @map("agreement_accepted_at")
  agreementName       String?   @map("agreement_name") // printed name typed by the customer
  agreementSignature  String?   @map("agreement_signature") // optional typed signature

  // Metadata
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  referrer  String?

  // ── Marketing attribution (Phase 2) — pushed to the marketing-tracker funnel
  //    on payment so booking revenue is attributed to its source / found-us. ──
  source  String? // QR src / tracking code carried by the booking URL
  foundUs String? @map("found_us") // "Where did you find us?" self-report

  // ── Stage 3 attribution (owner spec 2026-07-20) ──
  //    FIRST-TOUCH IS IMMUTABLE: it records how the customer originally found
  //    the business. Corrections go to ownerAssignedSource, never here — see
  //    marketing-profitability.canCorrectAttribution.
  firstTouchSource    String?   @map("first_touch_source")
  firstTouchCampaign  String?   @map("first_touch_campaign")
  firstTouchAt        DateTime? @map("first_touch_at")
  lastTouchSource     String?   @map("last_touch_source")
  lastTouchCampaign   String?   @map("last_touch_campaign")
  bookingSource       String?   @map("booking_source")
  bookingCampaign     String?   @map("booking_campaign")
  /// The source an owner decided to credit. Wins for BOOKING attribution.
  ownerAssignedSource String?   @map("owner_assigned_source")
  utmSource           String?   @map("utm_source")
  utmMedium           String?   @map("utm_medium")
  utmCampaign         String?   @map("utm_campaign")
  utmContent          String?   @map("utm_content")
  qrCampaign          String?   @map("qr_campaign")

  // ── Job completion (Phase 3) — set when the booking transitions to COMPLETED;
  //    the anchor time for the post-move follow-up sequence. ──
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer      Customer         @relation(fields: [customerId], references: [id])
  payments      Payment[]
  job           Job?
  files         File[]
  notifications Notification[]
  receipt       Receipt?
  auditLogs     AuditLog[]
  review        Review?
  followUps     FollowUpLedger[]
  expenses      Expense[] // job-linked expenses (admin OS) — reduce this job's profit
  closeout      MoveCloseout? // Phase 2 financial closeout

  @@index([status])
  @@index([customerId])
  @@index([confirmedDate])
  @@index([customerToken])
  // Stage 3 reporting: period scans, marketing rollups, city grouping.
  @@index([completedAt])
  @@index([source])
  @@index([ownerAssignedSource])
  @@index([originCity])
  @@map("bookings")
}

// ── Email outbox (src/outbox). Self-contained: bookingId is a plain reference
//    (no FK) so this table is decoupled from the Booking model. The unique
//    idempotency_key (bookingId::EVENT) + ON CONFLICT DO NOTHING is what makes
//    event creation exactly-once. ──
model EmailJob {
  id             String   @id @default(uuid())
  bookingId      String   @map("booking_id")
  eventType      String   @map("event_type")
  idempotencyKey String   @unique @map("idempotency_key") // `${bookingId}::${EVENT}`
  payload        Json
  status         String   @default("pending") // pending | processing | sent | failed
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5) @map("max_attempts")
  lastError      String?  @map("last_error")
  nextAttemptAt  DateTime @default(now()) @map("next_attempt_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt])
  @@index([bookingId])
  @@map("email_jobs")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @map("booking_id")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @unique @map("stripe_charge_id")
  amount                Int // in cents
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  /// HOW the money arrived (D1, Stage 4). Nullable because historical rows
  /// predate the column and their method is genuinely unknown — never guess.
  /// Stripe-originated rows are backfilled to STRIPE only where a Stripe id
  /// proves it. `metadata.method` is kept for compatibility but is no longer
  /// the source of truth.
  method                PaymentMethod?
  // Internal checkout tests (owner-flagged; mirrors Stripe metadata.internal_test).
  // EXCLUDED from every revenue aggregate/report. Never affects payment status.
  isInternalTest        Boolean       @default(false) @map("is_internal_test")
  description           String?
  receiptUrl            String?       @map("receipt_url")
  metadata              Json?
  // ── Refund + dispute tracking (additive; money truth stays in `status`).
  //    Cumulative refunded cents (monotonic); dispute id + raw Stripe status. ──
  refundedAmountCents   Int?          @map("refunded_amount_cents")
  stripeRefundId        String?       @map("stripe_refund_id")
  stripeDisputeId       String?       @map("stripe_dispute_id")
  disputeStatus         String?       @map("dispute_status")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([method])
  @@map("payments")
}

model Job {
  id           String    @id @default(cuid())
  bookingId    String    @unique @map("booking_id")
  status       JobStatus @default(SCHEDULED)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  durationMins Int?      @map("duration_mins")
  crewNotes    String?   @map("crew_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  booking     Booking                 @relation(fields: [bookingId], references: [id])
  crew        JobCrew[]
  files       File[]
  staffingReq JobStaffingRequirement?

  @@index([status])
  @@map("jobs")
}

model JobCrew {
  id         String   @id @default(cuid())
  jobId      String   @map("job_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // ── Payroll & time tracking (admin OS, owner spec 2026-07-13) — all nullable/
  //    defaulted so existing crew rows read cleanly. amountOwed is DERIVED in
  //    src/lib/profit.ts (never stored): flatPay if set, else payRate*actualHours,
  //    plus tips + bonus - deductions. payRate here overrides the User default. ──
  crewLeader     Boolean        @default(false) @map("crew_leader")
  scheduledHours Float?         @map("scheduled_hours")
  actualHours    Float?         @map("actual_hours")
  clockIn        DateTime?      @map("clock_in")
  clockOut       DateTime?      @map("clock_out")
  breakMinutes   Int?           @map("break_minutes")
  payRate        Int?           @map("pay_rate") // cents/hour; null => User.payRate
  flatPay        Int?           @map("flat_pay") // cents; overrides hourly when set
  tips           Int? // cents
  bonus          Int? // cents
  deductions     Int? // cents
  payMethod      PaymentMethod? @map("pay_method")
  payStatus      CrewPayStatus  @default(SCHEDULED) @map("pay_status")
  paidAt         DateTime?      @map("paid_at")
  payNotes       String?        @map("pay_notes")

  // ══ PHASE 1 LABOR SYSTEM (owner spec 2026-07-20) ═══════════════════════════
  //    This model is THE canonical financial labor record for a customer move.
  //    Everything above is retained and kept in SYNC by src/lib/labor-calc.ts so
  //    existing readers (reminder rules, dashboards) never break; everything
  //    below is the authoritative record going forward.
  //
  //    TIME IS STORED IN INTEGER MINUTES. The legacy Float `actualHours` /
  //    `scheduledHours` are derived mirrors — never the source of truth.
  //    MONEY IS INTEGER CENTS.

  // ── Identity ──
  workerType       CrewWorkerType       @default(EMPLOYEE) @map("worker_type")
  role             CrewRole             @default(CREW_MEMBER)
  assignmentStatus CrewAssignmentStatus @default(ASSIGNED) @map("assignment_status")
  /// Optional link to a Discord gig-board `crew_jobs` row. PLAIN REFERENCE, no
  /// FK by design (that table lives on an unmerged branch; same pattern as
  /// OwnerTransaction.bookingId). UNIQUE so a replayed Discord acceptance can
  /// never create a second assignment for one gig. A gig payout that arrives
  /// here becomes flatPayCentsSnapshot — counted ONCE, here. See
  /// docs/admin/discord-crew-integration.md.
  crewJobId        String?              @unique @map("crew_job_id")
  acceptedAt       DateTime?            @map("accepted_at")
  declinedAt       DateTime?            @map("declined_at")
  cancelledAt      DateTime?            @map("cancelled_at")
  cancelReason     String?              @map("cancel_reason")
  assignmentNotes  String?              @map("assignment_notes")

  // ── Stage 5 scheduling (owner spec 2026-07-21) ──
  //    JobCrew stays THE assignment record; these fill the gaps Stage 5 needs
  //    without a competing table. All nullable/defaulted so existing rows read
  //    cleanly and Stage 4 closeout reads are unaffected.
  offeredAt          DateTime? @map("offered_at")
  /// When the worker acknowledged (accepted). Distinct from acceptedAt only so a
  /// re-request after a material change can be tracked without losing the first.
  acknowledgedAt     DateTime? @map("acknowledged_at")
  /// Set when a material schedule change invalidates a prior acknowledgment; the
  /// worker must acknowledge again. Cleared on re-acknowledgment.
  acknowledgmentStaleAt DateTime? @map("acknowledgment_stale_at")
  declineReason      String?   @map("decline_reason")
  removedAt          DateTime? @map("removed_at")
  removalReason      String?   @map("removal_reason")
  completedAt        DateTime? @map("completed_at")
  noShowAt           DateTime? @map("no_show_at")
  /// When this worker should ARRIVE — may differ from the job's start.
  reportTime         DateTime? @map("report_time")
  /// Explicit driver designation. Not inferred from free text or role alone.
  isDriver           Boolean   @default(false) @map("is_driver")
  /// Notes the WORKER may see, kept apart from privateAdminNotes.
  workerVisibleNotes String?   @map("worker_visible_notes")
  privateAdminNotes  String?   @map("private_admin_notes")

  // ── Scheduled time ──
  scheduledStartAt       DateTime? @map("scheduled_start_at")
  scheduledEndAt         DateTime? @map("scheduled_end_at")
  scheduledBreakMinutes  Int?      @map("scheduled_break_minutes")
  scheduledMinutes       Int?      @map("scheduled_minutes") // derived, stored for reporting
  scheduledTravelMinutes Int?      @map("scheduled_travel_minutes")

  // ── Actual time (integer minutes) ──
  breakStartedAt     DateTime?        @map("break_started_at") // an open break, if any
  actualBreakMinutes Int?             @map("actual_break_minutes")
  workedMinutes      Int?             @map("worked_minutes") // elapsed − breaks
  regularMinutes     Int?             @map("regular_minutes")
  overtimeMinutes    Int?             @map("overtime_minutes")
  travelMinutes      Int?             @map("travel_minutes")
  paidMinutes        Int?             @map("paid_minutes") // regular + overtime + paid travel
  timeEntrySource    TimeEntrySource? @map("time_entry_source")
  timeAdjustedById   String?          @map("time_adjusted_by_id")
  timeAdjustedAt     DateTime?        @map("time_adjusted_at")
  timeAdjustReason   String?          @map("time_adjust_reason")

  // ── Pay model + RATE SNAPSHOTS ──
  //    Snapshots are taken at assignment. crewPayOwedCents must NEVER fall back
  //    to User.payRate for a snapshotted row: raising someone's rate today must
  //    not change what a move cost last month.
  payModel                  LaborPayModel   @default(HOURLY) @map("pay_model")
  hourlyRateCentsSnapshot   Int?            @map("hourly_rate_cents_snapshot")
  overtimeRateCentsSnapshot Int?            @map("overtime_rate_cents_snapshot")
  flatPayCentsSnapshot      Int?            @map("flat_pay_cents_snapshot")
  dayRateCentsSnapshot      Int?            @map("day_rate_cents_snapshot")
  travelPayPolicy           TravelPayPolicy @default(REGULAR) @map("travel_pay_policy")
  travelRateCentsSnapshot   Int?            @map("travel_rate_cents_snapshot")
  /// Replacement-cost rate for OWNER labor — what hiring someone would cost.
  /// Drives ECONOMIC profit; never cash.
  economicRateCentsSnapshot Int?            @map("economic_rate_cents_snapshot")
  rateSnapshotAt            DateTime?       @map("rate_snapshot_at")
  rateSnapshotSource        String?         @map("rate_snapshot_source") // user_profile | manual | crew_job | business_config
  rateAdjustedById          String?         @map("rate_adjusted_by_id")
  rateAdjustedAt            DateTime?       @map("rate_adjusted_at")
  rateAdjustReason          String?         @map("rate_adjust_reason")

  // ── Bonuses ──
  driverBonusCentsSnapshot     Int?    @map("driver_bonus_cents_snapshot")
  crewLeaderBonusCentsSnapshot Int?    @map("crew_leader_bonus_cents_snapshot")
  otherBonusCents              Int?    @map("other_bonus_cents")
  otherBonusReason             String? @map("other_bonus_reason")
  /// Labor-specific reimbursement (e.g. the worker bought straps). Distinct from
  /// an owner PERSONAL_PURCHASE, which lives in OwnerTransaction.
  reimbursementCents           Int?    @map("reimbursement_cents")
  reimbursementReason          String? @map("reimbursement_reason")

  // ── Calculated + approved ──
  calculatedPayCents Int?                @map("calculated_pay_cents") // what the formula produced
  approvedPayCents   Int?                @map("approved_pay_cents") // what the owner agreed to
  approvalStatus     LaborApprovalStatus @default(DRAFT) @map("approval_status")
  submittedAt        DateTime?           @map("submitted_at")
  submittedById      String?             @map("submitted_by_id")
  approvedById       String?             @map("approved_by_id")
  approvedAt         DateTime?           @map("approved_at")
  rejectedReason     String?             @map("rejected_reason")
  adjustmentReason   String?             @map("adjustment_reason")

  /// Explicit "$0 labor cost" confirmation. A MISSING assignment is never this —
  /// financial-completeness.ts keeps "unknown" and "confirmed zero" apart.
  zeroLaborConfirmed       Boolean   @default(false) @map("zero_labor_confirmed")
  zeroLaborConfirmedById   String?   @map("zero_labor_confirmed_by_id")
  zeroLaborConfirmedAt     DateTime? @map("zero_labor_confirmed_at")
  zeroLaborConfirmedReason String?   @map("zero_labor_confirmed_reason")

  // ── Payment state (amountPaid is DERIVED from laborPayments, never trusted raw) ──
  paymentStatus LaborPaymentStatus @default(UNPAID) @map("payment_status")

  // ── Audit ──
  createdById   String?  @map("created_by_id")
  createdByName String?  @map("created_by_name")
  updatedById   String?  @map("updated_by_id")
  sourceSystem  String?  @map("source_system") // admin | discord | import
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  job           Job            @relation(fields: [jobId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  laborPayments LaborPayment[]

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([approvalStatus])
  @@index([paymentStatus])
  @@index([assignmentStatus])
  @@index([scheduledStartAt])
  @@map("job_crew")
}

/// One recorded payment against ONE crew assignment. Supports partial payments,
/// so `amountPaid` is always SUM(non-voided rows) rather than a mutable column
/// that can drift. Recording a payment NEVER creates a business Expense row —
/// labor is recognized once, when accrued (docs/financial-architecture.md).
model LaborPayment {
  id             String        @id @default(cuid())
  jobCrewId      String        @map("job_crew_id")
  amountCents    Int           @map("amount_cents") // > 0; a correction is a void + re-record, not a negative
  method         PaymentMethod
  paidOn         DateTime      @map("paid_on")
  reference      String? // check no. / Zelle confirmation / etc.
  notes          String?
  proofUrl       String?       @map("proof_url")
  proofPublicId  String?       @map("proof_public_id")
  recordedById   String?       @map("recorded_by_id")
  recordedByName String?       @map("recorded_by_name")
  /// Voided payments are kept forever — never deleted — and count nowhere.
  voided         Boolean       @default(false)
  voidedById     String?       @map("voided_by_id")
  voidedAt       DateTime?     @map("voided_at")
  voidReason     String?       @map("void_reason")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  jobCrew JobCrew @relation(fields: [jobCrewId], references: [id], onDelete: Cascade)

  @@index([jobCrewId])
  @@index([paidOn])
  @@index([voided])
  @@map("labor_payments")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  isDayOff  Boolean  @default(false) @map("is_day_off")
  startTime String?  @map("start_time") // "08:00"
  endTime   String?  @map("end_time") // "18:00"
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@map("availability")
}

/// Admin-controlled blocked dates — no jobs scheduled on these days.
model DayBlock {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  blocked   Boolean  @default(true)
  blockedBy String?  @map("blocked_by")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("day_blocks")
}

// ════════════════════════════════════════════════════════════════════════════
//  STAGE 5 — crew scheduling (owner spec 2026-07-21)
//  Supporting tables around the existing User / Job / JobCrew records. None of
//  these is a second assignment source of truth — JobCrew stays canonical.
// ════════════════════════════════════════════════════════════════════════════

/// Recurring weekly availability. Times are integer MINUTES-from-midnight in the
/// stored `timezone`, so comparisons are explicit rather than string-parsed.
/// Multiple rows per (user, dayOfWeek) express multiple blocks in a day.
model AvailabilityRule {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  dayOfWeek   Int      @map("day_of_week") // 0 = Sunday … 6 = Saturday
  startMinute Int      @map("start_minute") // minutes from midnight, local
  endMinute   Int      @map("end_minute")
  timezone    String   @default("America/New_York")
  effectiveFrom DateTime? @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  active      Boolean  @default(true)
  notes       String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@map("availability_rules")
}

/// A date-specific exception that overrides the recurring rules for one worker.
model AvailabilityException {
  id          String                    @id @default(cuid())
  userId      String                    @map("user_id")
  kind        AvailabilityExceptionKind
  date        DateTime                  @db.Date
  /// For UNAVAILABLE_PARTIAL / AVAILABLE_OVERRIDE — the window, minutes local.
  startMinute Int?                      @map("start_minute")
  endMinute   Int?                      @map("end_minute")
  timezone    String                    @default("America/New_York")
  reason      String?
  createdById String?                   @map("created_by_id")
  createdAt   DateTime                  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([date])
  @@map("availability_exceptions")
}

/// What a job NEEDS, distinct from who is assigned. One row per job.
model JobStaffingRequirement {
  id               String      @id @default(cuid())
  jobId            String      @unique @map("job_id")
  minWorkers       Int         @default(1) @map("min_workers")
  requiredWorkers  Int         @default(2) @map("required_workers")
  preferredWorkers Int?        @map("preferred_workers")
  requiredDrivers  Int         @default(1) @map("required_drivers")
  requiresLead     Boolean     @default(true) @map("requires_lead")
  requiredSkills   CrewSkill[] @default([]) @map("required_skills")

  estimatedStartAt DateTime? @map("estimated_start_at")
  estimatedEndAt   DateTime? @map("estimated_end_at")
  reportTime       DateTime? @map("report_time")
  expectedBreakMinutes Int?  @map("expected_break_minutes")
  additionalStops  Int       @default(0) @map("additional_stops")

  // Job characteristics — inform staffing and pay, never the customer price.
  hasStairs           Boolean @default(false) @map("has_stairs")
  hasElevator         Boolean @default(false) @map("has_elevator")
  longCarry           Boolean @default(false) @map("long_carry")
  heavyItems          Boolean @default(false) @map("heavy_items")
  packing             Boolean @default(false)
  assembly            Boolean @default(false)
  customerProvidedTruck Boolean @default(false) @map("customer_provided_truck")
  rentalTruckPickup   Boolean @default(false) @map("rental_truck_pickup")
  drivingRequired     Boolean @default(true) @map("driving_required")
  outOfState          Boolean @default(false) @map("out_of_state")

  loadingLocation   String? @map("loading_location")
  unloadingLocation String? @map("unloading_location")
  workerInstructions String? @map("worker_instructions")
  privateNotes      String? @map("private_notes")

  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_staffing_requirements")
}

/// A pending crew invitation. The token is the acceptance credential; the actual
/// auth account is created by the existing setup flow (see the invitation docs).
model CrewInvitation {
  id             String           @id @default(cuid())
  email          String
  name           String
  phone          String?
  role           UserRole         @default(CREW)
  workerType     CrewWorkerType   @default(EMPLOYEE) @map("worker_type")
  initialRateCents Int?           @map("initial_rate_cents")
  initialSkills  CrewSkill[]      @default([]) @map("initial_skills")
  canDrive       Boolean          @default(false) @map("can_drive")
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  invitedById    String           @map("invited_by_id")
  acceptedByUserId String?        @map("accepted_by_user_id")
  acceptedAt     DateTime?        @map("accepted_at")
  cancelledAt    DateTime?        @map("cancelled_at")
  cancelledById  String?          @map("cancelled_by_id")
  resentAt       DateTime?        @map("resent_at")
  resendCount    Int              @default(0) @map("resend_count")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@map("crew_invitations")
}

/// A documented override of a scheduling conflict. Records exactly what was
/// waved through and by whom, so an overridden warning is auditable forever.
model ConflictOverride {
  id            String   @id @default(cuid())
  jobId         String   @map("job_id")
  jobCrewId     String?  @map("job_crew_id")
  userId        String?  @map("user_id") // the worker the conflict was about
  code          String
  details       Json?
  reason        String
  overriddenById String  @map("overridden_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@index([jobCrewId])
  @@map("conflict_overrides")
}

/// The scheduled/sent state of one assignment notification. `dedupeKey` makes
/// the queue job idempotent: re-enqueuing the same key never doubles a reminder.
model AssignmentNotification {
  id             String    @id @default(cuid())
  jobCrewId      String    @map("job_crew_id")
  type           String
  dedupeKey      String    @unique @map("dedupe_key")
  scheduledFor   DateTime? @map("scheduled_for")
  sentAt         DateTime? @map("sent_at")
  cancelledAt    DateTime? @map("cancelled_at")
  providerResult String?   @map("provider_result")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([jobCrewId])
  @@map("assignment_notifications")
}

model File {
  id            String   @id @default(cuid())
  bookingId     String?  @map("booking_id")
  jobId         String?  @map("job_id")
  type          FileType
  cloudinaryId  String   @unique @map("cloudinary_id")
  cloudinaryUrl String   @map("cloudinary_url")
  filename      String
  mimeType      String   @map("mime_type")
  sizeBytes     Int      @map("size_bytes")
  uploadedBy    String?  @map("uploaded_by") // user ID or "customer"
  createdAt     DateTime @default(now()) @map("created_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  job     Job?     @relation(fields: [jobId], references: [id])

  @@index([bookingId])
  @@index([jobId])
  @@map("files")
}

model Receipt {
  id            String    @id @default(cuid())
  bookingId     String    @unique @map("booking_id")
  cloudinaryId  String?   @map("cloudinary_id")
  cloudinaryUrl String?   @map("cloudinary_url")
  sentAt        DateTime? @map("sent_at")
  sentTo        String?   @map("sent_to")
  createdAt     DateTime  @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("receipts")
}

model Notification {
  id        String              @id @default(cuid())
  bookingId String?             @map("booking_id")
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  recipient String // email / phone / discord channel
  subject   String?
  template  String // template name
  payload   Json // template data
  bullJobId String?             @map("bull_job_id")
  sentAt    DateTime?           @map("sent_at")
  error     String?
  retries   Int                 @default(0)
  // Email open tracking (1x1 tracking-pixel). openToken is embedded in the
  // sent email; GET /api/email/open stamps openedAt + isOpened on first load
  // and bumps openCount on every load. Only meaningful for EMAIL channel.
  openToken String?             @unique @map("open_token")
  openedAt  DateTime?           @map("opened_at")
  isOpened  Boolean             @default(false) @map("is_opened")
  openCount Int                 @default(0) @map("open_count")
  createdAt DateTime            @default(now()) @map("created_at")

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("notifications")
}

model WebhookLog {
  id          String    @id @default(cuid())
  source      String // "stripe" | "discord"
  eventType   String    @map("event_type")
  eventId     String?   @unique @map("event_id") // idempotency key
  payload     Json
  status      String // "processed" | "failed" | "duplicate"
  error       String?
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([source])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_logs")
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  userId    String?     @map("user_id") // null = system
  bookingId String?     @map("booking_id")
  details   Json?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  result    Json?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum ManualEventType {
  QUOTE // price quote given
  VISIT // went out in person
  ONSITE // customer wants the quote on-site
  NOBOOK // customer chose not to book
  JOBACCEPT // customer gave a verbal yes
  FOLLOWUP // needs a follow-up / call back
}

/// Field events logged manually by the crew from Discord (/quote, /visit, /onsite,
/// /nobook, /jobaccept, /followup). First-party ground truth from the field to
/// complement the automated booking + payment data above. Standalone by design —
/// these capture leads who never entered the booking flow.
model ManualEvent {
  id           String          @id @default(cuid())
  eventType    ManualEventType @map("event_type")
  customerName String?         @map("customer_name")
  zip          String?
  jobType      String?         @map("job_type")
  notes        String?
  loggedBy     String?         @map("logged_by") // Discord user tag who entered it
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([eventType])
  @@index([zip])
  @@index([createdAt])
  @@map("manual_events")
}

enum TaskOwner {
  DIEGO
  SEBASTIAN
}

enum TaskStatus {
  OPEN
  DONE
}

/// Owner task board (#owner-tasks). Manually-created tasks for Diego & Sebastian,
/// ranked by importance (5 = highest), then due date, then due time. Created from
/// Discord slash commands (/task_add, /task_list, …).
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  importance  Int        @default(3) // 1–5, 5 = highest priority
  owner       TaskOwner
  dueDate     DateTime   @map("due_date") // calendar date, stored at UTC midnight
  dueTime     String?    @map("due_time") // optional, normalized "HH:MM" 24h for sorting
  status      TaskStatus @default(OPEN)
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([owner])
  @@index([dueDate])
  @@map("tasks")
}

/// Exactly-once ledger for post-job customer follow-ups (Phase 3). A row is
/// written BEFORE the message is sent, so the @@unique([bookingId, type]) is the
/// hard anti-spam guarantee: a BullMQ retry, a double completion trigger, or a
/// re-enqueue can never send the same follow-up twice. `referral-ask` is shared
/// by the positive-review path and the day-5 fallback, so the customer gets at
/// most ONE referral ask per booking.
model FollowUpLedger {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  type      String // review-request | review-reminder | repeat-reminder | referral-ask
  channel   String   @default("both") // sms | email | both
  /// OVERALL state (finding EMAIL-P1-10). This used to default to "sent" and be
  /// written BEFORE either channel delivered, so the ledger — and every report
  /// built on it — claimed a delivery that may never have happened. An SMS
  /// merely ENQUEUED counted as sent. Queueing is not delivery.
  ///   planned | claimed | deferred | partially_delivered | delivered
  ///   | failed_retryable | failed_terminal | cancelled | skipped
  status    String   @default("planned")
  error     String?
  /// Per-channel truth. `both` no longer hides that one side failed, and a
  /// retry can target ONLY the failed channel instead of re-sending the one
  /// that succeeded.
  ///   not_applicable | pending | queued | delivered | failed
  emailStatus     String?   @map("email_status")
  smsStatus       String?   @map("sms_status")
  emailAttempts   Int       @default(0) @map("email_attempts")
  smsAttempts     Int       @default(0) @map("sms_attempts")
  emailProviderId String?   @map("email_provider_id")
  smsProviderId   String?   @map("sms_provider_id")
  emailLastError  String?   @map("email_last_error")
  smsLastError    String?   @map("sms_last_error")
  /// When a deferred/retryable follow-up may be attempted again.
  nextAttemptAt   DateTime? @map("next_attempt_at")
  /// Why a terminal row is terminal (opted-out, not-completed, ineligible…).
  terminalReason  String?   @map("terminal_reason")
  /// First delivery on ANY channel. Null until something really shipped.
  deliveredAt     DateTime? @map("delivered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  /// Retained for back-compat with existing rows/readers.
  sentAt    DateTime @default(now()) @map("sent_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, type])
  @@index([bookingId])
  @@index([status, nextAttemptAt])
  @@map("followup_ledger")
}

/// Customer review of a completed move (Phase 3). Recorded by staff (admin UI /
/// Discord command) or the customer portal — there is no Google review webhook,
/// so the rating is captured first-party. A positive review (rating >= 4) fires
/// exactly one referral ask and suppresses the 48h review reminder.
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique @map("booking_id")
  rating     Int // 1..5
  isPositive Boolean  @default(false) @map("is_positive")
  source     String   @default("admin") // admin | discord | customer-portal
  comment    String?
  leftAt     DateTime @default(now()) @map("left_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("reviews")
}

// ============================================================
// ADMIN OPERATING SYSTEM — the money spine (owner spec 2026-07-13)
// Rule: every dollar connects to a JOB (Expense.bookingId set), an OWNER
// transaction (OwnerTransaction), or a GENERAL business expense (Expense with
// no bookingId). This keeps revenue, real profit, worker pay, and personal
// money from ever mixing together.
// ============================================================

/// A cost the business paid. bookingId set => a JOB expense that reduces THAT
/// job's profit. bookingId null => a GENERAL business expense (Railway, ads,
/// insurance…) that reduces monthly business profit without touching one job.
/// Receipt is stored as the Cloudinary URL from /api/files/upload (no File FK,
/// mirroring EmailJob's plain-reference decoupling). createdBy is denormalized
/// (id + name) like AuditLog details — no relation churn on User.
model Expense {
  id              String          @id @default(cuid())
  amount          Int // cents
  incurredOn      DateTime        @map("incurred_on")
  category        ExpenseCategory
  vendor          String?
  paymentMethod   PaymentMethod?  @map("payment_method")
  paidBy          String?         @map("paid_by") // owner name / worker / "business"
  bookingId       String?         @map("booking_id") // null = general business expense
  purpose         String? // business purpose
  receiptUrl      String?         @map("receipt_url")
  receiptPublicId String?         @map("receipt_public_id")
  reimbursable    Boolean         @default(false)
  status          ExpenseStatus   @default(SUBMITTED)
  notes           String?
  createdById     String?         @map("created_by_id")
  createdByName   String?         @map("created_by_name")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([category])
  @@index([status])
  @@index([incurredOn])
  @@map("expenses")
}

/// Diego / Sebastian owner money — kept OUT of business expenses on purpose so
/// personal cash never contaminates job profit. Reuses TaskOwner (DIEGO |
/// SEBASTIAN). bookingId is an optional plain reference (e.g. a distribution
/// tied to a specific job); no FK by design.
model OwnerTransaction {
  id              String               @id @default(cuid())
  owner           TaskOwner
  amount          Int // cents
  type            OwnerTransactionType
  occurredOn      DateTime             @map("occurred_on")
  paymentMethod   PaymentMethod?       @map("payment_method")
  explanation     String?
  receiptUrl      String?              @map("receipt_url")
  receiptPublicId String?              @map("receipt_public_id")
  approvalStatus  ApprovalStatus       @default(PENDING) @map("approval_status")
  bookingId       String?              @map("booking_id") // optional plain reference
  createdById     String?              @map("created_by_id")
  createdByName   String?              @map("created_by_name")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([owner])
  @@index([type])
  @@index([occurredOn])
  @@map("owner_transactions")
}

/// A sales lead in the pipeline (NEW -> CONTACTED -> QUOTE_SENT -> FOLLOW_UP ->
/// BOOKED | LOST). Standalone from ManualEvent (field-log) and Booking — this is
/// the funnel + marketing-source attribution. convertedBookingId is a plain
/// reference set when a lead becomes a real booking (revenue-by-source report).
model Lead {
  id                 String          @id @default(cuid())
  name               String
  phone              String?
  email              String?
  source             LeadSource      @default(OTHER)
  status             LeadStatus      @default(NEW)
  lostReason         LeadLostReason? @map("lost_reason")
  estimatedValue     Int?            @map("estimated_value") // cents
  jobType            String?         @map("job_type")
  moveDate           DateTime?       @map("move_date")
  zip                String?
  notes              String?
  assignedTo         String?         @map("assigned_to")
  convertedBookingId String?         @map("converted_booking_id") // plain reference

  // ── Ingestion + attribution (createOrUpdateLead, 2026-07-15) — all nullable,
  //    additive. Populated by the shared lead-ingestion service from the contact
  //    form, coupon popup, "not sure" bookings, and the marketing tracker. ──
  message        String?
  originCity     String?   @map("origin_city")
  destCity       String?   @map("dest_city")
  utmSource      String?   @map("utm_source")
  utmMedium      String?   @map("utm_medium")
  utmCampaign    String?   @map("utm_campaign")
  utmContent     String?   @map("utm_content")
  utmTerm        String?   @map("utm_term")
  landingPage    String?   @map("landing_page")
  referrer       String?
  promoCode      String?   @map("promo_code")
  lastActivityAt DateTime? @map("last_activity_at")
  contactedAt    DateTime? @map("contacted_at")
  quotedAt       DateTime? @map("quoted_at")
  bookedAt       DateTime? @map("booked_at")
  lostAt         DateTime? @map("lost_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([email])
  @@index([phone])
  @@index([lastActivityAt])
  @@map("leads")
}

/// Action Center reminder (increment 2, owner spec 2026-07-13). Rows are
/// created by DETERMINISTIC rules in src/lib/reminder-rules.ts (no AI) via the
/// sync in src/lib/reminder-sync.ts. dedupeKey (rule + entity) is the anti-spam
/// guarantee: a rule re-run updates the existing row instead of duplicating it.
/// System reminders auto-RESOLVE when the underlying condition clears and can
/// REOPEN if it returns; DISMISSED is a human decision the scanner respects.
/// History is never hard-deleted through owner actions.
model Reminder {
  id               String           @id @default(cuid())
  reminderType     String           @map("reminder_type") // stable rule id, e.g. "job-24h-no-crew"
  category         ReminderCategory
  title            String
  description      String
  severity         ReminderSeverity
  status           ReminderStatus   @default(OPEN)
  sourceEntityType String?          @map("source_entity_type") // booking | expense | lead | customer | crew
  sourceEntityId   String?          @map("source_entity_id")
  sourceUrl        String?          @map("source_url") // admin deep link
  dedupeKey        String           @unique @map("dedupe_key")
  dueAt            DateTime?        @map("due_at")
  snoozedUntil     DateTime?        @map("snoozed_until")
  assignedOwner    TaskOwner?       @map("assigned_owner")
  createdBy        String           @default("system") @map("created_by")
  internalNote     String?          @map("internal_note") // owner note; preserved across rule re-runs
  resolutionNote   String?          @map("resolution_note")
  metadata         Json?
  acknowledgedAt   DateTime?        @map("acknowledged_at")
  startedAt        DateTime?        @map("started_at")
  resolvedAt       DateTime?        @map("resolved_at")
  dismissedAt      DateTime?        @map("dismissed_at")

  // ── Lifecycle & accountability (increment 2.1) — all nullable/defaulted ──
  //    entityFingerprint = deterministic hash of the candidate's material state
  //    (severity + dueAt + description). A dismissal with OCCURRENCE or
  //    UNTIL_ENTITY_CHANGES scope reopens when it changes. dismissalScope drives
  //    whether a dismissed reminder can ever return.
  assignedAt        DateTime?       @map("assigned_at")
  assignedByName    String?         @map("assigned_by_name")
  claimedById       String?         @map("claimed_by_id")
  claimedByName     String?         @map("claimed_by_name")
  claimedAt         DateTime?       @map("claimed_at")
  completedById     String?         @map("completed_by_id")
  completedByName   String?         @map("completed_by_name")
  dismissalScope    DismissalScope? @map("dismissal_scope")
  dismissedById     String?         @map("dismissed_by_id")
  dismissedByName   String?         @map("dismissed_by_name")
  entityFingerprint String?         @map("entity_fingerprint")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([dueAt])
  @@index([assignedOwner])
  @@index([sourceEntityType, sourceEntityId])
  @@map("reminders")
}

/// Reminder scan run metadata (increment 2.1). Every full Action Center scan
/// records a row so the UI can show the last successful / last failed scan, the
/// current running state, and per-scan counts. A Postgres advisory lock (see
/// src/lib/scan-lock.ts) prevents two scans from overlapping; a RUNNING row
/// older than the stale timeout is treated as crashed.
model ScanRun {
  id                String      @id @default(cuid())
  status            ScanStatus  @default(RUNNING)
  trigger           ScanTrigger
  startedAt         DateTime    @default(now()) @map("started_at")
  completedAt       DateTime?   @map("completed_at")
  durationMs        Int?        @map("duration_ms")
  triggeredById     String?     @map("triggered_by_id")
  triggeredByName   String?     @map("triggered_by_name")
  rulesEvaluated    Int?        @map("rules_evaluated")
  entitiesEvaluated Int?        @map("entities_evaluated")
  remindersCreated  Int?        @map("reminders_created")
  remindersUpdated  Int?        @map("reminders_updated")
  remindersReopened Int?        @map("reminders_reopened")
  remindersResolved Int?        @map("reminders_resolved")
  remindersSkipped  Int?        @map("reminders_skipped")
  errorCount        Int         @default(0) @map("error_count")
  errorSummary      String?     @map("error_summary") // sanitized — never secrets/PII
  worker            String? // process/service identifier when known

  @@index([status])
  @@index([startedAt])
  @@map("scan_runs")
}

/// Ideas & Roadmap item (increment 2). Structured product/business planning —
/// not a notes page. seedKey makes the preloaded gap items idempotent (the seed
/// endpoint skips keys that already exist). comments is an append-only JSON
/// array of {by, at, text}. No hard delete — REJECTED/ARCHIVED instead.
model RoadmapItem {
  id              String          @id @default(cuid())
  seedKey         String?         @unique @map("seed_key")
  title           String
  summary         String?
  problem         String? // business problem
  solution        String? // proposed solution
  benefit         String? // expected benefit
  risks           String?
  priority        RoadmapPriority @default(MEDIUM)
  status          RoadmapStatus   @default(IDEA)
  category        RoadmapCategory @default(OTHER)
  impact          Int? // 1-5
  effort          Int? // 1-5
  dependencies    String?
  blockers        String?
  assignedOwner   TaskOwner?      @map("assigned_owner")
  targetIncrement String?         @map("target_increment")
  notes           String?
  comments        Json? // [{by, at, text}]
  rejectionReason String?         @map("rejection_reason")
  completedAt     DateTime?       @map("completed_at")
  createdBy       String?         @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([priority])
  @@map("roadmap_items")
}

/// Single-row business configuration (ownership split + cash reserves). The
/// ownership split NEVER means all cash is distributable — the Owner Money page
/// subtracts upcoming worker pay + bills + tax/emergency reserves first.
model BusinessConfig {
  id                    String @id @default("singleton")
  diegoSplitPercent     Int    @default(50) @map("diego_split_percent")
  sebastianSplitPercent Int    @default(50) @map("sebastian_split_percent")
  taxReservePercent     Int    @default(25) @map("tax_reserve_percent") // % of profit held for taxes
  emergencyReserveCents Int    @default(0) @map("emergency_reserve_cents")

  // ── Phase 1 labor policy (owner spec 2026-07-20) ──
  /// What an owner's hour is WORTH if it had to be hired out. Drives ECONOMIC
  /// profit only — never cash, never a payable. Default $30/h.
  ownerEconomicRateCents   Int @default(3000) @map("owner_economic_rate_cents")
  /// Minutes in a day beyond which time is overtime. 0 disables overtime.
  /// Default 480 (8h). NJ has no daily-OT statute; this is a house policy.
  overtimeThresholdMinutes Int @default(480) @map("overtime_threshold_minutes")
  /// Overtime multiplier in percent (150 = 1.5x).
  overtimeMultiplierPct    Int @default(150) @map("overtime_multiplier_pct")
  /// Shift length (minutes) past which a time entry is flagged for review
  /// rather than rejected — long move days are legitimate. Default 840 (14h).
  longShiftReviewMinutes   Int @default(840) @map("long_shift_review_minutes")

  // ── Phase 2 closeout policy (owner spec 2026-07-20) ──
  /// Default overhead method + rate. SNAPSHOT at finalization; changing these
  /// must never alter an already-finalized move.
  overheadMethod            OverheadMethod @default(NONE) @map("overhead_method")
  overheadPerMoveCents      Int            @default(0) @map("overhead_per_move_cents")
  overheadPctRevenueBp      Int            @default(0) @map("overhead_pct_revenue_bp") // basis points (500 = 5%)
  overheadPerLaborHourCents Int            @default(0) @map("overhead_per_labor_hour_cents")
  overheadMonthlyPoolCents  Int            @default(0) @map("overhead_monthly_pool_cents")
  /// Receipts required at or above this amount. 0 disables the rule.
  receiptRequiredAboveCents Int            @default(2500) @map("receipt_required_above_cents")
  /// Default business reserve taken from company net profit, in basis points.
  generalReserveBp          Int            @default(0) @map("general_reserve_bp")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_config")
}

// ════════════════════════════════════════════════════════════════════════════
//  PHASE 2 — financial closeout (owner spec 2026-07-20)
// ════════════════════════════════════════════════════════════════════════════

/// The closeout workflow for ONE move. Exactly one row per booking (unique), so
/// there can never be two competing closeouts. Money lives in FinancialSnapshot;
/// this model owns WORKFLOW state, the checklist, and the confirmations that
/// only a human can make (truck source, "$0 confirmed", write-offs).
model MoveCloseout {
  id        String         @id @default(cuid())
  bookingId String         @unique @map("booking_id")
  status    CloseoutStatus @default(NOT_STARTED)

  startedAt     DateTime? @map("started_at")
  startedById   String?   @map("started_by_id")
  submittedAt   DateTime? @map("submitted_at")
  submittedById String?   @map("submitted_by_id")
  finalizedAt   DateTime? @map("finalized_at")
  finalizedById String?   @map("finalized_by_id")
  reopenedAt    DateTime? @map("reopened_at")
  reopenedById  String?   @map("reopened_by_id")
  reopenReason  String?   @map("reopen_reason")

  /// Blockers an OWNER deliberately overrode, with the reason. Shape:
  /// [{ code, reason, byId, byName, at }] — never a bare boolean.
  overrides Json?
  notes     String?

  // ── Human confirmations. These exist because their ABSENCE is meaningful:
  //    a missing truck cost is not $0 until somebody says so.
  truckSource              TruckSource? @map("truck_source")
  truckSourceConfirmedAt   DateTime?    @map("truck_source_confirmed_at")
  truckSourceConfirmedById String?      @map("truck_source_confirmed_by_id")
  /// Owner accepted that an outstanding customer balance will not be collected.
  balanceWriteOffCents     Int?         @map("balance_write_off_cents")
  balanceWriteOffReason    String?      @map("balance_write_off_reason")
  /// Owner acknowledged an open dispute so it stops blocking finalization.
  disputeAcknowledgedAt    DateTime?    @map("dispute_acknowledged_at")

  // ── Reserve + split decisions for THIS move (applied at finalization) ──
  overheadMethod      OverheadMethod? @map("overhead_method")
  overheadAmountCents Int?            @map("overhead_amount_cents")
  overheadReason      String?         @map("overhead_reason")
  taxReserveBp        Int?            @map("tax_reserve_bp") // basis points of company net profit
  taxReserveCents     Int?            @map("tax_reserve_cents")
  taxReserveReason    String?         @map("tax_reserve_reason")
  /// The company-retained share in basis points, FROZEN at finalization so a
  /// later BusinessConfig change can never rewrite a closed move (D4).
  businessRetainedBp  Int?            @map("business_retained_bp")
  splitMethod         SplitMethod?    @map("split_method")
  splitReason         String?         @map("split_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// RESTRICT, not Cascade: deleting a booking must never destroy the immutable
  /// FinancialSnapshot rows hanging off this closeout (P1-2). A booking that
  /// carries financial history cannot be deleted at all.
  booking   Booking             @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  snapshots FinancialSnapshot[]
  reserves  ReserveAllocation[]

  @@index([status])
  @@index([finalizedAt])
  @@map("move_closeouts")
}

/// An IMMUTABLE record of the numbers used at one finalization. Never updated —
/// reopening creates version N+1 and marks the previous one superseded.
///
/// THIS IS THE POINT OF PHASE 2: changing a worker rate, an ownership split, a
/// reserve percentage or an overhead policy must NOT silently rewrite a move
/// that was already closed. Historical truth reads from here, not from live
/// configuration.
model FinancialSnapshot {
  id         String @id @default(cuid())
  closeoutId String @map("closeout_id")
  bookingId  String @map("booking_id")
  version    Int

  // revenue
  netBilledRevenueCents    Int @map("net_billed_revenue_cents")
  netCollectedRevenueCents Int @map("net_collected_revenue_cents")
  outstandingBalanceCents  Int @map("outstanding_balance_cents")
  refundedCents            Int @map("refunded_cents")
  chargebackCents          Int @map("chargeback_cents")
  disputedOpenCents        Int @map("disputed_open_cents")

  // costs
  directExpenseCents      Int @map("direct_expense_cents")
  crewLaborCents          Int @map("crew_labor_cents")
  ownerCashLaborCents     Int @map("owner_cash_labor_cents")
  ownerEconomicLaborCents Int @map("owner_economic_labor_cents")
  processingFeeCents      Int @map("processing_fee_cents")
  truckCostCents          Int @map("truck_cost_cents")
  directJobCostCents      Int @map("direct_job_cost_cents")

  // profit
  cashGrossProfitCents   Int  @map("cash_gross_profit_cents")
  economicProfitCents    Int  @map("economic_profit_cents")
  allocatedOverheadCents Int  @map("allocated_overhead_cents")
  companyNetProfitCents  Int  @map("company_net_profit_cents")
  economicNetProfitCents Int  @map("economic_net_profit_cents")
  marginBp               Int? @map("margin_bp") // basis points; null when no revenue

  // reserves + distribution
  taxReserveCents          Int   @map("tax_reserve_cents")
  /// 40/30/30 policy, as applied to THIS move at THIS moment (Stage 4).
  /// Rate + resolved dollars are both stored so the snapshot explains itself
  /// without re-reading BusinessConfig.
  businessRetainedBp       Int   @default(0) @map("business_retained_bp")
  businessRetainedCents    Int   @default(0) @map("business_retained_cents")
  /// Integer-cent remainder after the owner shares; stays with the business.
  roundingRemainderCents   Int   @default(0) @map("rounding_remainder_cents")
  businessReserveCents     Int   @map("business_reserve_cents")
  retainedEarningsCents    Int   @map("retained_earnings_cents")
  unresolvedLiabilityCents Int   @map("unresolved_liability_cents")
  distributableProfitCents Int   @map("distributable_profit_cents")
  /// [{ owner, amountCents, percentBp }] — what each owner was allocated.
  ownerAllocations         Json? @map("owner_allocations")
  /// The owner-facing 40/30/30 lines EXACTLY as presented at finalization:
  /// [{ label, ofNetProfitBp, amountCents, isBusiness }]. Stored so a report,
  /// an export or a printed summary can restate a closed move without ever
  /// re-reading live BusinessConfig. See src/lib/profit-allocation.ts.
  allocationLines          Json? @map("allocation_lines")

  // provenance
  overheadMethod     OverheadMethod @map("overhead_method")
  overheadRateRaw    Int?           @map("overhead_rate_raw")
  taxReserveBp       Int?           @map("tax_reserve_bp")
  splitMethod        SplitMethod?   @map("split_method")
  /// Flags for anything still incomplete when this was taken.
  incompleteFlags    Json?          @map("incomplete_flags")
  calculationVersion String         @map("calculation_version")
  /// WHERE the retained rate came from — "closeout.frozen" once a move has been
  /// finalized before, "business_config" on a first finalization, "default"
  /// when no policy was configured at all.
  configSource       String?        @map("config_source")
  /// WHICH configuration produced it: BusinessConfig.updatedAt at finalization.
  /// Together with configSource this makes a historical figure explainable
  /// after the policy has moved on.
  configVersion      String?        @map("config_version")

  supersededAt   DateTime? @map("superseded_at")
  supersededById String?   @map("superseded_by_id")
  createdById    String?   @map("created_by_id")
  createdByName  String?   @map("created_by_name")
  createdAt      DateTime  @default(now()) @map("created_at")

  closeout MoveCloseout @relation(fields: [closeoutId], references: [id], onDelete: Cascade)

  @@unique([closeoutId, version])
  @@index([bookingId])
  @@index([supersededAt])
  @@map("financial_snapshots")
}

/// Money the business is holding back. PLANNED by default — this records an
/// accounting decision, NOT a bank transfer. `transferredAt` is only set when a
/// real movement is confirmed by a human.
model ReserveAllocation {
  id            String      @id @default(cuid())
  closeoutId    String?     @map("closeout_id")
  bookingId     String?     @map("booking_id")
  kind          ReserveKind
  amountCents   Int         @map("amount_cents")
  reason        String?
  /// True only when the money actually moved somewhere. Never inferred.
  transferred   Boolean     @default(false)
  transferredAt DateTime?   @map("transferred_at")
  createdById   String?     @map("created_by_id")
  createdByName String?     @map("created_by_name")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  closeout MoveCloseout? @relation(fields: [closeoutId], references: [id], onDelete: Cascade)

  @@index([closeoutId])
  @@index([kind])
  @@map("reserve_allocations")
}

/// An owner profit distribution. Distinct from a WITHDRAWAL (a draw), a
/// REIMBURSEMENT (money already the owner's), and labor pay. Allocation and
/// actual payment are separate: `approvedCents` is the decision, `paidCents` is
/// the cash. A distribution can NEVER exceed the distributable profit that was
/// snapshotted.
model OwnerDistribution {
  id         String             @id @default(cuid())
  owner      TaskOwner
  bookingId  String?            @map("booking_id") // plain reference; null = period distribution
  snapshotId String?            @map("snapshot_id") // the snapshot it was authorized against
  status     DistributionStatus @default(PLANNED)

  approvedCents Int            @map("approved_cents")
  paidCents     Int            @default(0) @map("paid_cents")
  percentBp     Int?           @map("percent_bp")
  method        PaymentMethod?
  paidOn        DateTime?      @map("paid_on")
  reference     String?
  notes         String?

  approvedById   String?   @map("approved_by_id")
  approvedByName String?   @map("approved_by_name")
  approvedAt     DateTime? @map("approved_at")
  recordedById   String?   @map("recorded_by_id")
  voided         Boolean   @default(false)
  voidedById     String?   @map("voided_by_id")
  voidedAt       DateTime? @map("voided_at")
  voidReason     String?   @map("void_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([owner])
  @@index([bookingId])
  @@index([status])
  @@map("owner_distributions")
}

// ════════════════════════════════════════════════════════════════════════════
//  STAGE 3 — reporting, marketing profitability, exports (owner spec 2026-07-20)
// ════════════════════════════════════════════════════════════════════════════

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignChannel {
  DOOR_HANGER
  YARD_SIGN
  QR_CODE
  GOOGLE_ADS
  META_ADS
  GOOGLE_BUSINESS
  MARKETPLACE
  INSTAGRAM
  EMAIL
  REFERRAL_PROGRAM
  PARTNERSHIP
  WEBSITE
  PHONE
  OTHER
}

enum SpendKind {
  PRINT
  DISTRIBUTION
  AD_SPEND
  PLATFORM_FEE
  CREATIVE
  ADJUSTMENT
  OTHER
}

enum ReportExportStatus {
  SUCCESS
  FAILED
}

/// A marketing campaign. Profit ROAS = attributed FINALIZED company net profit
/// / total spend, so a campaign is judged by money made, never by scans.
model MarketingCampaign {
  id          String          @id @default(cuid())
  name        String
  channel     CampaignChannel
  /// The attribution source string this campaign owns (matches Booking.source
  /// / UTM values), so attributed moves can be found without guessing.
  sourceKey   String          @map("source_key")
  status      CampaignStatus  @default(DRAFT)
  startDate   DateTime?       @map("start_date")
  endDate     DateTime?       @map("end_date")
  budgetCents Int?            @map("budget_cents")

  // Door-hanger / print specifics
  printQuantity    Int?    @map("print_quantity")
  distributionArea String? @map("distribution_area")
  creativeVersion  String? @map("creative_version")
  offer            String?
  landingPageUrl   String? @map("landing_page_url")
  qrIdentifier     String? @unique @map("qr_identifier")
  phoneIdentifier  String? @map("phone_identifier")
  notes            String?

  createdById   String?  @map("created_by_id")
  createdByName String?  @map("created_by_name")
  updatedById   String?  @map("updated_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  spend MarketingSpend[]

  @@index([status])
  @@index([sourceKey])
  @@index([channel])
  @@map("marketing_campaigns")
}

/// One cost against a campaign. Kept as rows rather than a single total so the
/// spend is auditable and a correction is an entry, not an overwrite.
model MarketingSpend {
  id          String    @id @default(cuid())
  campaignId  String    @map("campaign_id")
  kind        SpendKind
  amountCents Int       @map("amount_cents")
  incurredOn  DateTime  @map("incurred_on")
  vendor      String?
  reference   String?
  notes       String?
  /// True for a monthly/ongoing cost, so it is not mistaken for one-time spend.
  recurring   Boolean   @default(false)
  receiptUrl  String?   @map("receipt_url")

  createdById   String?  @map("created_by_id")
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([incurredOn])
  @@map("marketing_spend")
}

/// A saved report configuration. Stores FILTERS ONLY - never user-supplied
/// query code - so a saved view can never become an injection vector.
model SavedReportView {
  id         String   @id @default(cuid())
  reportType String   @map("report_type")
  name       String
  /// Structured, validated filter object. Never raw SQL.
  filters    Json
  sortKey    String?  @map("sort_key")
  sortDir    String?  @map("sort_dir")
  columns    String[]
  periodKey  String?  @map("period_key")
  scope      String?
  basis      String?
  shared     Boolean  @default(false)

  createdById   String   @map("created_by_id")
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([createdById, reportType, name])
  @@index([reportType])
  @@index([shared])
  @@map("saved_report_views")
}

/// An audit record of a report leaving the building. Deliberately records the
/// SHAPE of the export (filters, columns, row count) and never its contents -
/// logging the file would recreate the disclosure the controls exist to prevent.
model ReportExport {
  id          String             @id @default(cuid())
  reportType  String             @map("report_type")
  format      String
  periodLabel String             @map("period_label")
  basisLabel  String             @map("basis_label")
  filters     Json?
  columnKeys  String[]           @map("column_keys")
  recordCount Int                @map("record_count")
  status      ReportExportStatus @default(SUCCESS)
  error       String?

  requestedById   String   @map("requested_by_id")
  requestedByName String?  @map("requested_by_name")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([reportType])
  @@index([requestedById])
  @@index([createdAt])
  @@map("report_exports")
}

// ═══════════════════════════════════════════════════════════════════════════
//  EMAIL LIFECYCLE (owner spec 2026-07-20) — suppression, send ledger, events.
//
//  These three models are the release-blocker foundation the email system was
//  missing: there was no way to record an unsubscribe, no way to act on a hard
//  bounce or spam complaint, no durable per-send record, and no idempotency
//  key — so a worker retry after a successful provider call could resend.
//
//  All three are ADDITIVE. Nothing existing reads or writes them yet, so the
//  migration is safe to apply ahead of the code that uses it.
// ═══════════════════════════════════════════════════════════════════════════

/// Why an address may no longer receive email. Ordered loosely by severity.
/// UNSUBSCRIBED blocks PROMOTIONAL only; every other reason blocks ALL mail
/// (a hard-bouncing or complaining address must not be written to at all).
enum SuppressionReason {
  UNSUBSCRIBED
  HARD_BOUNCE
  SPAM_COMPLAINT
  INVALID_ADDRESS
  ADMIN_BLOCK
  PROVIDER_REJECTED
}

/// The ONE global do-not-send list, keyed on the lowercased address so it works
/// for Customers, Leads, and anyone Leadtracking (SendGrid) knows about but this
/// database does not. `scope` records whether the block is promotional-only.
model EmailSuppression {
  id        String            @id @default(cuid())
  /// Always stored lowercased + trimmed. Unique = the list is idempotent.
  email     String            @unique
  reason    SuppressionReason
  /// 'promotional' (unsubscribe) | 'all' (bounce/complaint/invalid/admin).
  scope     String            @default("all")
  /// Where the signal came from: 'unsubscribe-link' | 'resend-webhook' |
  /// 'leadtracking' | 'admin' | 'sms-stop'.
  source    String?
  /// Free-text provider detail (bounce sub-type, complaint feedback id, …).
  detail    String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([reason])
  @@index([createdAt])
  @@map("email_suppressions")
}

/// One row per attempted send. Claimed BEFORE the provider call, so a crash or
/// retry after a successful send finds the row and refuses to send again.
/// `idempotencyKey` is the exactly-once guarantee (see src/lib/email-guard.ts).
model EmailSend {
  id             String    @id @default(cuid())
  /// recipient + template + journey + qualifying-event id + template version.
  idempotencyKey String    @unique @map("idempotency_key")
  email          String
  template       String
  /// 'transactional' | 'promotional' — drives suppression scope + frequency caps.
  emailClass     String    @map("email_class")
  /// Lifecycle journey this send belongs to, when it is part of one.
  journey        String?
  bookingId      String?   @map("booking_id")
  leadId         String?   @map("lead_id")
  campaign       String?
  /// ATTEMPT STATE MACHINE (findings EMAIL-P1-03 / EMAIL-P1-04).
  /// Previously this was 'claimed'|'sent'|'blocked'|'failed', and the unique
  /// idempotencyKey was consumed by the FIRST outcome whatever it was — so a
  /// provider 500 or a quiet-hours deferral permanently prevented the email
  /// from ever being sent. Delivery IDENTITY (the key) is now separate from
  /// ATTEMPT OUTCOME (this status): a non-terminal row is RESUMED in place.
  ///   sending           — an attempt is in flight
  ///   delivered         — provider accepted; terminal, never re-sent
  ///   provider_rejected — known rejection, no provider id; retryable
  ///   retry_pending     — awaiting another attempt
  ///   ambiguous         — request left us, outcome unknown; NEVER auto-resent
  ///   deferred          — policy says later (quiet hours, caps, gap)
  ///   blocked_retryable — temporary block (DB outage, missing config/URL)
  ///   blocked_terminal  — permanent block (hard suppression, ineligible state)
  ///   failed_terminal   — attempts exhausted
  status         String    @default("sending")
  /// Coarse classification for reporting: terminal | retryable | deferred | ambiguous.
  outcomeClass   String?   @map("outcome_class")
  /// Why a blocked/deferred row is not sending (machine-readable).
  blockedReason  String?   @map("blocked_reason")
  /// Attempt counter across resumes of the SAME logical send.
  attempts       Int       @default(0)
  /// Earliest time a deferred/retryable row may be attempted again.
  nextAttemptAt  DateTime? @map("next_attempt_at")
  /// Resend message id, once accepted.
  providerId     String?   @map("provider_id")
  error          String?
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  events EmailEvent[]

  @@index([email])
  @@index([status])
  @@index([journey])
  @@index([bookingId])
  @@index([leadId])
  @@index([createdAt])
  /// Drives the retry/deferral sweep.
  @@index([status, nextAttemptAt])
  /// FREQUENCY-CAP QUERY (finding EMAIL-P2-18): countSentSince() filters on
  /// email + emailClass + status + sentAt. A composite index keeps that a range
  /// scan rather than a scan of every send to the address.
  @@index([email, emailClass, status, sentAt])
  @@map("email_sends")
}

/// Provider + first-party engagement events. `providerEventId` is unique so a
/// duplicate webhook delivery is a no-op (providers retry aggressively).
model EmailEvent {
  id                 String   @id @default(cuid())
  /// Provider event id, or a synthesized stable id for first-party events.
  providerEventId    String   @unique @map("provider_event_id")
  emailSendId        String?  @map("email_send_id")
  email              String
  /// 'delivered' | 'bounced' | 'complained' | 'opened' | 'clicked' |
  /// 'delivery_delayed' | 'unsubscribed'
  type               String
  /// Raw provider payload excerpt for triage (never PII beyond the address).
  detail             String?
  /// SIDE-EFFECT PROCESSING STATE (finding EMAIL-P0-01).
  /// Recording the event and APPLYING its consequence (suppressing a bounced or
  /// complaining address) are two different things. Previously only the record
  /// existed, so a failed suppression write left an address permanently
  /// sendable while the unique providerEventId deduplicated away every retry.
  /// 'processed'          — no side effect needed, or it completed
  /// 'side_effect_pending'— a suppression is required and not yet confirmed
  /// 'side_effect_failed' — the suppression write failed; MUST be retried
  /// 'dead_letter'        — exhausted retries; needs a human
  processingStatus   String   @default("processed") @map("processing_status")
  /// How many times the side effect has been attempted.
  sideEffectAttempts Int      @default(0) @map("side_effect_attempts")
  /// Last side-effect error, for triage.
  sideEffectError    String?  @map("side_effect_error")
  occurredAt         DateTime @default(now()) @map("occurred_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  emailSend EmailSend? @relation(fields: [emailSendId], references: [id])

  @@index([email])
  @@index([type])
  @@index([emailSendId])
  @@index([occurredAt])
  /// Drives the retry sweep for unfinished side effects.
  @@index([processingStatus])
  @@map("email_events")
}
