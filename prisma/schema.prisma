// ============================================================
// PRISMA SCHEMA — We Move It. We Clear It.
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CREW
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_APPROVAL
  CONFIRMED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
  CANCELLED
}

// ── Outbox state machine (src/outbox). Independent of BookingStatus above;
//    stored in bookings.outbox_state and drives the email-outbox transitions. ──
enum BookingState {
  PAYMENT_PENDING
  PENDING_APPROVAL
  APPROVED
  CONFIRMED
  RESCHEDULE_REQUESTED
}

enum DiscountType {
  FIRST_TIME_AUTO     // 10% automatic for new customers
  DOOR_HANGER_PENDING // 30% claimed, awaiting approval
  DOOR_HANGER_APPROVED// 30% approved by owner
  DOOR_HANGER_DENIED  // denied, fallback offered
  MANUAL              // manually applied by staff
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum NotificationChannel {
  EMAIL
  SMS
  DISCORD
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FileType {
  PHOTO_BEFORE
  PHOTO_AFTER
  PAPERWORK
  RECEIPT
  OTHER
}

enum AuditAction {
  BOOKING_CREATED
  BOOKING_STATE_CHANGED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  DISCOUNT_APPLIED
  DISCOUNT_APPROVED
  DISCOUNT_DENIED
  JOB_STARTED
  JOB_COMPLETED
  FILE_UPLOADED
  FILE_DELETED
  RECEIPT_SENT
  USER_LOGIN
  USER_LOGOUT
  SCHEDULE_MODIFIED
  AVAILABILITY_SET
}

// ── MODELS ────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(CREW)
  discordId    String?   @map("discord_id")
  phone        String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  availability  Availability[]
  assignedJobs  JobCrew[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Customer {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  phone        String
  isFirstTime  Boolean   @default(true) @map("is_first_time")
  // Preferred language for all customer-facing email + SMS ("en" | "es").
  // Captured from the marketing site's EN/ES toggle at booking time.
  locale       String    @default("en")
  // TCPA marketing opt-out — set true when a customer texts STOP (inbound SMS
  // webhook). Phase-3 follow-ups are suppressed for opted-out customers. The 4
  // transactional booking messages are unaffected (they're not marketing).
  marketingOptOut Boolean @default(false) @map("marketing_opt_out")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  bookings     Booking[]

  @@map("customers")
}

model Booking {
  id              String        @id @default(cuid())
  displayId       String        @unique @default(cuid()) @map("display_id") // human-friendly
  status          BookingStatus @default(DRAFT)
  outboxState     BookingState? @map("outbox_state") // src/outbox email state machine (additive, nullable)
  customerId      String        @map("customer_id")

  // Location
  originAddress   String        @map("origin_address")
  destAddress     String        @map("dest_address")
  originFloor     Int?          @map("origin_floor")
  destFloor       Int?          @map("dest_floor")
  hasElevator     Boolean       @default(false) @map("has_elevator")

  // Items
  itemsDescription String?      @map("items_description")
  estimatedHours   Float?       @map("estimated_hours")

  // Schedule
  requestedDate   DateTime?     @map("requested_date")
  confirmedDate   DateTime?     @map("confirmed_date")
  scheduledStart  DateTime?     @map("scheduled_start")
  scheduledEnd    DateTime?     @map("scheduled_end")

  // Reschedule tracking — the $49 hold stays attached across reschedules.
  previousRequestedDate DateTime? @map("previous_requested_date")
  rescheduleCount       Int       @default(0) @map("reschedule_count")
  rescheduledAt         DateTime? @map("rescheduled_at")

  // Pricing
  depositAmount   Int           @default(4900) @map("deposit_amount") // cents — $49 booking fee
  depositPaid     Boolean       @default(false) @map("deposit_paid")
  truckAddonDueOnMoveDay Boolean @default(false) @map("truck_addon_due_on_move_day")
  truckAddonAmount Int          @default(0) @map("truck_addon_amount") // cents
  baseRate        Float?        @map("base_rate")
  totalEstimate   Float?        @map("total_estimate")
  finalAmount     Float?        @map("final_amount")

  // Discount
  discountCode    String?       @map("discount_code")
  discountType    DiscountType? @map("discount_type")
  discountPercent Float?        @map("discount_percent")
  discountApprovedById String?  @map("discount_approved_by_id")

  // Stripe
  stripeCheckoutId  String?     @unique @map("stripe_checkout_id")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")

  // Discord
  discordJobChannelId      String? @map("discord_job_channel_id")
  discordPaperworkChannelId String? @map("discord_paperwork_channel_id")
  discordPhotosChannelId   String? @map("discord_photos_channel_id")
  discordApprovalMessageId String? @map("discord_approval_message_id")

  // Self-service token for customer portal
  customerToken   String        @unique @default(cuid()) @map("customer_token")
  customerTokenExpiry DateTime  @map("customer_token_expiry")

  // Notes
  internalNotes   String?       @map("internal_notes")
  customerNotes   String?       @map("customer_notes")

  // Moving Service Agreement (legal acceptance record)
  agreementAccepted   Boolean   @default(false) @map("agreement_accepted")
  agreementVersion    String?   @map("agreement_version")
  agreementAcceptedAt DateTime? @map("agreement_accepted_at")
  agreementName       String?   @map("agreement_name")      // printed name typed by the customer
  agreementSignature  String?   @map("agreement_signature") // optional typed signature

  // Metadata
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  referrer        String?

  // ── Marketing attribution (Phase 2) — pushed to the marketing-tracker funnel
  //    on payment so booking revenue is attributed to its source / found-us. ──
  source          String?       // QR src / tracking code carried by the booking URL
  foundUs         String?       @map("found_us") // "Where did you find us?" self-report

  // ── Job completion (Phase 3) — set when the booking transitions to COMPLETED;
  //    the anchor time for the post-move follow-up sequence. ──
  completedAt     DateTime?     @map("completed_at")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  customer        Customer      @relation(fields: [customerId], references: [id])
  payments        Payment[]
  job             Job?
  files           File[]
  notifications   Notification[]
  receipt         Receipt?
  auditLogs       AuditLog[]
  review          Review?
  followUps       FollowUpLedger[]

  @@index([status])
  @@index([customerId])
  @@index([confirmedDate])
  @@index([customerToken])
  @@map("bookings")
}

// ── Email outbox (src/outbox). Self-contained: bookingId is a plain reference
//    (no FK) so this table is decoupled from the Booking model. The unique
//    idempotency_key (bookingId::EVENT) + ON CONFLICT DO NOTHING is what makes
//    event creation exactly-once. ──
model EmailJob {
  id             String   @id @default(uuid())
  bookingId      String   @map("booking_id")
  eventType      String   @map("event_type")
  idempotencyKey String   @unique @map("idempotency_key") // `${bookingId}::${EVENT}`
  payload        Json
  status         String   @default("pending") // pending | processing | sent | failed
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5) @map("max_attempts")
  lastError      String?  @map("last_error")
  nextAttemptAt  DateTime @default(now()) @map("next_attempt_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt])
  @@index([bookingId])
  @@map("email_jobs")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @map("booking_id")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @unique @map("stripe_charge_id")
  amount                Int           // in cents
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  description           String?
  receiptUrl            String?       @map("receipt_url")
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  booking               Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Job {
  id           String    @id @default(cuid())
  bookingId    String    @unique @map("booking_id")
  status       JobStatus @default(SCHEDULED)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  durationMins Int?      @map("duration_mins")
  crewNotes    String?   @map("crew_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  booking      Booking   @relation(fields: [bookingId], references: [id])
  crew         JobCrew[]
  files        File[]

  @@index([status])
  @@map("jobs")
}

model JobCrew {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  userId    String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  job       Job      @relation(fields: [jobId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@map("job_crew")
}

model Availability {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  date       DateTime @db.Date
  isDayOff   Boolean  @default(false) @map("is_day_off")
  startTime  String?  @map("start_time") // "08:00"
  endTime    String?  @map("end_time")   // "18:00"
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@map("availability")
}

/// Admin-controlled blocked dates — no jobs scheduled on these days.
model DayBlock {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  blocked   Boolean  @default(true)
  blockedBy String?  @map("blocked_by")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("day_blocks")
}

model File {
  id            String    @id @default(cuid())
  bookingId     String?   @map("booking_id")
  jobId         String?   @map("job_id")
  type          FileType
  cloudinaryId  String    @unique @map("cloudinary_id")
  cloudinaryUrl String    @map("cloudinary_url")
  filename      String
  mimeType      String    @map("mime_type")
  sizeBytes     Int       @map("size_bytes")
  uploadedBy    String?   @map("uploaded_by") // user ID or "customer"
  createdAt     DateTime  @default(now()) @map("created_at")

  booking       Booking?  @relation(fields: [bookingId], references: [id])
  job           Job?      @relation(fields: [jobId], references: [id])

  @@index([bookingId])
  @@index([jobId])
  @@map("files")
}

model Receipt {
  id            String    @id @default(cuid())
  bookingId     String    @unique @map("booking_id")
  cloudinaryId  String?   @map("cloudinary_id")
  cloudinaryUrl String?   @map("cloudinary_url")
  sentAt        DateTime? @map("sent_at")
  sentTo        String?   @map("sent_to")
  createdAt     DateTime  @default(now()) @map("created_at")

  booking       Booking   @relation(fields: [bookingId], references: [id])

  @@map("receipts")
}

model Notification {
  id         String              @id @default(cuid())
  bookingId  String?             @map("booking_id")
  channel    NotificationChannel
  status     NotificationStatus  @default(QUEUED)
  recipient  String              // email / phone / discord channel
  subject    String?
  template   String              // template name
  payload    Json                // template data
  bullJobId  String?             @map("bull_job_id")
  sentAt     DateTime?           @map("sent_at")
  error      String?
  retries    Int                 @default(0)
  createdAt  DateTime            @default(now()) @map("created_at")

  booking    Booking?            @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("notifications")
}

model WebhookLog {
  id          String    @id @default(cuid())
  source      String    // "stripe" | "discord"
  eventType   String    @map("event_type")
  eventId     String?   @unique @map("event_id") // idempotency key
  payload     Json
  status      String    // "processed" | "failed" | "duplicate"
  error       String?
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([source])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_logs")
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  userId    String?     @map("user_id") // null = system
  bookingId String?     @map("booking_id")
  details   Json?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  user      User?       @relation(fields: [userId], references: [id])
  booking   Booking?    @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  result    Json?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum ManualEventType {
  QUOTE // price quote given
  VISIT // went out in person
  ONSITE // customer wants the quote on-site
  NOBOOK // customer chose not to book
  JOBACCEPT // customer gave a verbal yes
  FOLLOWUP // needs a follow-up / call back
}

/// Field events logged manually by the crew from Discord (/quote, /visit, /onsite,
/// /nobook, /jobaccept, /followup). First-party ground truth from the field to
/// complement the automated booking + payment data above. Standalone by design —
/// these capture leads who never entered the booking flow.
model ManualEvent {
  id           String          @id @default(cuid())
  eventType    ManualEventType @map("event_type")
  customerName String?         @map("customer_name")
  zip          String?
  jobType      String?         @map("job_type")
  notes        String?
  loggedBy     String?         @map("logged_by") // Discord user tag who entered it
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([eventType])
  @@index([zip])
  @@index([createdAt])
  @@map("manual_events")
}

enum TaskOwner {
  DIEGO
  SEBASTIAN
}

enum TaskStatus {
  OPEN
  DONE
}

/// Owner task board (#owner-tasks). Manually-created tasks for Diego & Sebastian,
/// ranked by importance (5 = highest), then due date, then due time. Created from
/// Discord slash commands (/task_add, /task_list, …).
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  importance  Int        @default(3) // 1–5, 5 = highest priority
  owner       TaskOwner
  dueDate     DateTime   @map("due_date") // calendar date, stored at UTC midnight
  dueTime     String?    @map("due_time") // optional, normalized "HH:MM" 24h for sorting
  status      TaskStatus @default(OPEN)
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([owner])
  @@index([dueDate])
  @@map("tasks")
}

/// Exactly-once ledger for post-job customer follow-ups (Phase 3). A row is
/// written BEFORE the message is sent, so the @@unique([bookingId, type]) is the
/// hard anti-spam guarantee: a BullMQ retry, a double completion trigger, or a
/// re-enqueue can never send the same follow-up twice. `referral-ask` is shared
/// by the positive-review path and the day-5 fallback, so the customer gets at
/// most ONE referral ask per booking.
model FollowUpLedger {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  type      String   // review-request | review-reminder | repeat-reminder | referral-ask
  channel   String   @default("both") // sms | email | both
  status    String   @default("sent") // sent | failed | skipped
  error     String?
  sentAt    DateTime @default(now()) @map("sent_at")

  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, type])
  @@index([bookingId])
  @@map("followup_ledger")
}

/// Customer review of a completed move (Phase 3). Recorded by staff (admin UI /
/// Discord command) or the customer portal — there is no Google review webhook,
/// so the rating is captured first-party. A positive review (rating >= 4) fires
/// exactly one referral ask and suppresses the 48h review reminder.
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique @map("booking_id")
  rating     Int      // 1..5
  isPositive Boolean  @default(false) @map("is_positive")
  source     String   @default("admin") // admin | discord | customer-portal
  comment    String?
  leftAt     DateTime @default(now()) @map("left_at")

  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("reviews")
}
