// ============================================================
// PRISMA SCHEMA — Move It Clear It
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CREW
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_APPROVAL
  CONFIRMED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
  CANCELLED
}

// ── Outbox state machine (src/outbox). Independent of BookingStatus above;
//    stored in bookings.outbox_state and drives the email-outbox transitions. ──
enum BookingState {
  PAYMENT_PENDING
  PENDING_APPROVAL
  APPROVED
  CONFIRMED
  RESCHEDULE_REQUESTED
}

enum DiscountType {
  FIRST_TIME_AUTO // 10% automatic for new customers
  DOOR_HANGER_PENDING // 30% claimed, awaiting approval
  DOOR_HANGER_APPROVED // 30% approved by owner
  DOOR_HANGER_DENIED // denied, fallback offered
  MANUAL // manually applied by staff
}

// Travel service-area zone for a booking (see src/lib/service-area.ts).
enum ServiceAreaZone {
  primary // Essex County + nearby — no travel fee
  extended_nj // rest of New Jersey — $50 travel fee (due on move day)
  new_york // New York — manual review, no fixed fee
  manual_review // could not classify the address — manual review
  unsupported // outside NJ/NY — manual review
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum NotificationChannel {
  EMAIL
  SMS
  DISCORD
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FileType {
  PHOTO_BEFORE
  PHOTO_AFTER
  PAPERWORK
  RECEIPT
  OTHER
}

enum AuditAction {
  BOOKING_CREATED
  BOOKING_STATE_CHANGED
  BOOKING_DETAILS_UPDATED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  PAYMENT_DISPUTED
  DISCOUNT_APPLIED
  DISCOUNT_APPROVED
  DISCOUNT_DENIED
  JOB_STARTED
  JOB_COMPLETED
  FILE_UPLOADED
  FILE_DELETED
  RECEIPT_SENT
  USER_LOGIN
  USER_LOGOUT
  SCHEDULE_MODIFIED
  AVAILABILITY_SET
  // ── Admin operating system (owner spec 2026-07-13) ──
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  EXPENSE_DELETED
  OWNER_TRANSACTION_CREATED
  OWNER_TRANSACTION_UPDATED
  OWNER_TRANSACTION_DELETED
  CREW_ASSIGNED
  CREW_PAY_UPDATED
  CREW_PAID
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  PRICE_CHANGED
  BUSINESS_CONFIG_UPDATED
  // ── Action Center + Ideas & Roadmap (increment 2, owner spec 2026-07-13) ──
  REMINDER_UPDATED
  ROADMAP_CREATED
  ROADMAP_UPDATED
  // ── Hardening (increment 2.1, owner spec 2026-07-13) ──
  REMINDER_DISMISSED
  REMINDER_RESTORED
  FINANCIAL_ADJUSTMENT
  WORKER_PAY_OVERRIDE
}

// ── Hardening enums (increment 2.1) ──────────────────────────────────────────

enum ScanStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ScanTrigger {
  MANUAL
  SCHEDULED
  API
  PAGE_LOAD
}

// Dismissal scope (owner spec 2.1): OCCURRENCE reopens if the condition clears
// and returns OR the entity materially changes; UNTIL_ENTITY_CHANGES reopens
// only when the fingerprint changes; PERMANENT_RULE_ENTITY never reopens
// automatically (owner-only, reason required, restorable).
enum DismissalScope {
  OCCURRENCE
  UNTIL_ENTITY_CHANGES
  PERMANENT_RULE_ENTITY
}

// ── Action Center enums (increment 2). "Critical / Due Today / Upcoming /
//    Completed" from the owner spec are computed GROUPINGS in the UI (severity,
//    dueAt, status) — not stored categories. ──────────────────────────────────

enum ReminderSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum ReminderStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  SNOOZED
  RESOLVED
  DISMISSED
}

enum ReminderCategory {
  BOOKING_DATA
  JOBS_SCHEDULING
  FINANCIAL
  CUSTOMER_BALANCE
  CREW_PAYROLL
  LEADS
  DATA_QUALITY
}

// ── Ideas & Roadmap enums (increment 2) ──────────────────────────────────────

enum RoadmapStatus {
  IDEA
  RESEARCHING
  PLANNED
  READY
  IN_PROGRESS
  BLOCKED
  COMPLETED
  REJECTED
  ARCHIVED
}

enum RoadmapPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RoadmapCategory {
  FINANCIAL
  REPORTS
  JOBS
  SCHEDULING
  PAYROLL
  LEADS
  MARKETING
  CUSTOMERS
  PAYMENTS
  EQUIPMENT
  FLEET
  DOCUMENTS
  NOTIFICATIONS
  SECURITY
  AI
  WEBSITE
  BOOKING_FORM
  SYSTEM
  OTHER
}

// ── Admin operating system enums (owner spec 2026-07-13) ──────────────────────
//    The money spine: every dollar is a job expense, an owner transaction, or a
//    general business expense. These enums back those three ledgers + payroll.

enum ExpenseCategory {
  WORKER_PAY
  GAS
  TOLLS
  PARKING
  TRUCK_RENTAL
  MOVING_EQUIPMENT
  MOVING_BLANKETS
  STRAPS_DOLLIES
  ADVERTISING
  WEBSITE_SOFTWARE
  INSURANCE
  PHONE
  CREW_FOOD
  REFUNDS
  OFFICE
  LEGAL_REGISTRATION
  SUPPLIES
  MISC
}

enum ExpenseStatus {
  SUBMITTED
  NEEDS_REVIEW
  APPROVED
  REJECTED
  REIMBURSED
}

// Shared across expenses, owner transactions, and crew pay — how money moved.
enum PaymentMethod {
  CASH
  CARD
  ZELLE
  VENMO
  CASHAPP
  BANK_TRANSFER
  CHECK
  OTHER
}

enum OwnerTransactionType {
  CONTRIBUTION // owner put money in
  WITHDRAWAL // owner took money out
  REIMBURSEMENT // business paying an owner back for personal spend
  DISTRIBUTION // profit distribution to an owner
  PERSONAL_PURCHASE // business purchase made with an owner's personal money (reimbursable)
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadSource {
  GOOGLE
  FACEBOOK
  INSTAGRAM
  DOOR_HANGER
  YARD_SIGN
  REFERRAL
  CRAIGSLIST
  OFFERUP
  RETURNING_CUSTOMER
  WEBSITE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTE_SENT
  FOLLOW_UP
  BOOKED
  LOST
}

enum LeadLostReason {
  PRICE_TOO_HIGH
  NO_RESPONSE
  DATE_UNAVAILABLE
  CHOSE_COMPETITOR
  NEEDED_IMMEDIATE
  OUTSIDE_SERVICE_AREA
  OTHER
}

enum CrewPayStatus {
  SCHEDULED
  CHECKED_IN
  WORKING
  COMPLETED
  PAY_APPROVED
  PAID
}

// ── MODELS ────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(CREW)
  discordId    String?  @map("discord_id")
  phone        String?
  active       Boolean  @default(true)

  // ── HR / payroll (admin OS, owner spec 2026-07-13) — all nullable ──
  //    payRate is the DEFAULT cents/hour; a JobCrew row can override it per job.
  payRate               Int?    @map("pay_rate") // cents per hour
  preferredRole         String? @map("preferred_role")
  emergencyContact      String? @map("emergency_contact")
  emergencyContactPhone String? @map("emergency_contact_phone")
  reliabilityRating     Int?    @map("reliability_rating") // 1-5
  performanceNotes      String? @map("performance_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  availability Availability[]
  assignedJobs JobCrew[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Customer {
  id              String  @id @default(cuid())
  email           String  @unique
  name            String
  phone           String
  isFirstTime     Boolean @default(true) @map("is_first_time")
  // Preferred language for all customer-facing email + SMS ("en" | "es").
  // Captured from the marketing site's EN/ES toggle at booking time.
  locale          String  @default("en")
  // TCPA marketing opt-out — set true when a customer texts STOP (inbound SMS
  // webhook). Phase-3 follow-ups are suppressed for opted-out customers. The 4
  // transactional booking messages are unaffected (they're not marketing).
  marketingOptOut Boolean @default(false) @map("marketing_opt_out")

  // ── Extended contact (admin operations, owner spec 2026-07-12) — all nullable ──
  preferredName         String? @map("preferred_name")
  secondaryPhone        String? @map("secondary_phone")
  emergencyContact      String? @map("emergency_contact")
  emergencyContactPhone String? @map("emergency_contact_phone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  bookings Booking[]

  @@map("customers")
}

model Booking {
  id               String        @id @default(cuid())
  displayId        String        @unique @default(cuid()) @map("display_id") // mirrors bookingReference for back-compat
  // Public, human-friendly booking reference (WMIC-####). Backed by an atomic
  // Postgres sequence (booking_reference_seq) so concurrent inserts can never
  // collide; assigned once at creation and never changed. The internal cuid `id`
  // stays the private key used for all relationships/joins/webhooks. Nullable so
  // historical/internal-test rows may stay unreferenced. See src/lib/booking-reference.ts.
  bookingReference String?       @unique @map("booking_reference")
  status           BookingStatus @default(DRAFT)
  outboxState      BookingState? @map("outbox_state") // src/outbox email state machine (additive, nullable)
  // Owner checkout tests (mirrors Payment.isInternalTest). EXCLUDED from every
  // operational count + revenue report. Flagged by scripts/flag-test-bookings.ts.
  isInternalTest   Boolean       @default(false) @map("is_internal_test")
  customerId       String        @map("customer_id")

  // Location
  originAddress String  @map("origin_address")
  destAddress   String  @map("dest_address")
  originFloor   Int?    @map("origin_floor")
  destFloor     Int?    @map("dest_floor")
  hasElevator   Boolean @default(false) @map("has_elevator")

  // Items
  itemsDescription String? @map("items_description")
  estimatedHours   Float?  @map("estimated_hours")

  // Schedule
  requestedDate  DateTime? @map("requested_date")
  confirmedDate  DateTime? @map("confirmed_date")
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")

  // Reschedule tracking — the $49 hold stays attached across reschedules.
  previousRequestedDate DateTime? @map("previous_requested_date")
  rescheduleCount       Int       @default(0) @map("reschedule_count")
  rescheduledAt         DateTime? @map("rescheduled_at")

  // Pricing
  depositAmount          Int     @default(4900) @map("deposit_amount") // cents — $49 booking fee
  depositPaid            Boolean @default(false) @map("deposit_paid")
  truckAddonDueOnMoveDay Boolean @default(false) @map("truck_addon_due_on_move_day")
  truckAddonAmount       Int     @default(0) @map("truck_addon_amount") // cents
  baseRate               Float?  @map("base_rate")
  totalEstimate          Float?  @map("total_estimate")
  finalAmount            Float?  @map("final_amount")

  // ── Service area / travel fee (server-computed; see src/lib/service-area.ts) ──
  //    travelFee is charged on move day like the truck add-on — never in Stripe.
  serviceAreaZone             ServiceAreaZone? @map("service_area_zone")
  travelFee                   Int              @default(0) @map("travel_fee") // cents; 0 = none
  travelFeeDueOnMoveDay       Boolean          @default(false) @map("travel_fee_due_on_move_day")
  manualReviewRequired        Boolean          @default(false) @map("manual_review_required")
  serviceAreaMessage          String?          @map("service_area_message")
  distanceFromWestOrangeMiles Float?           @map("distance_from_west_orange_miles")
  estimatedDriveTimeMinutes   Int?             @map("estimated_drive_time_minutes")
  addressEvaluation           Json?            @map("address_evaluation")

  // Discount
  discountCode         String?       @map("discount_code")
  discountType         DiscountType? @map("discount_type")
  discountPercent      Float?        @map("discount_percent")
  discountApprovedById String?       @map("discount_approved_by_id")

  // Stripe
  stripeCheckoutId      String? @unique @map("stripe_checkout_id")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")

  // Discord
  discordJobChannelId       String? @map("discord_job_channel_id")
  discordPaperworkChannelId String? @map("discord_paperwork_channel_id")
  discordPhotosChannelId    String? @map("discord_photos_channel_id")
  discordApprovalMessageId  String? @map("discord_approval_message_id")

  // Self-service token for customer portal
  customerToken       String   @unique @default(cuid()) @map("customer_token")
  customerTokenExpiry DateTime @map("customer_token_expiry")

  // Notes
  internalNotes String? @map("internal_notes")
  customerNotes String? @map("customer_notes")

  // ── Structured access details (owner spec 2026-07-12) ────────────────────
  //    Backward-compatible: EVERY field is nullable, so existing bookings read
  //    as null. Pickup (origin*) and drop-off (dest*) are kept separate.
  //    originFloor/destFloor above are REUSED for the floor number (no dupes).
  //    SENSITIVE: origin/destAccessCode are gate/lockbox/buzzer codes — surfaced
  //    ONLY in the owner-gated Discord "View Full Booking" + authorized admin
  //    views; they are omitted from the customer portal API and never written to
  //    itemsDescription (which feeds public emails + the customer summary).
  originUnit        String?  @map("origin_unit") // apartment / unit #
  destUnit          String?  @map("dest_unit")
  originHasElevator Boolean? @map("origin_has_elevator") // per-location elevator
  destHasElevator   Boolean? @map("dest_has_elevator")
  originStairCount  Int?     @map("origin_stair_count") // flights / approx count
  destStairCount    Int?     @map("dest_stair_count")
  originAccessNotes String?  @map("origin_access_notes") // parking/loading + building access (non-sensitive)
  destAccessNotes   String?  @map("dest_access_notes")
  originAccessCode  String?  @map("origin_access_code") // SENSITIVE
  destAccessCode    String?  @map("dest_access_code") // SENSITIVE

  // Customer-provided truck details — informational only. The $50 pickup/return
  // FEE stays governed by truckAddonDueOnMoveDay/truckAddonAmount (no new fee).
  truckProvider             String? @map("truck_provider") // customer / U-Haul / Penske / WMIWCI
  truckSize                 String? @map("truck_size") // 10ft / 15ft / 26ft …
  truckReservationStatus    String? @map("truck_reservation_status") // reserved / not-yet / n/a
  truckPickupLocation       String? @map("truck_pickup_location")
  truckReturnResponsibility String? @map("truck_return_responsibility")

  equipmentNeeds   String? @map("equipment_needs") // dollies/straps/piano board (informational)
  crewInstructions String? @map("crew_instructions") // customer's move-day instructions for the crew

  // ── Verified structured address (Phase 2, owner spec 2026-07-12). Written by
  //    SERVER-side Google Address Validation only — client-claimed components are
  //    never persisted. Nullable: legacy bookings read as NULL and display the
  //    originAddress/destAddress strings. verification_status:
  //    verified | partial | unverified | skipped (no provider key/timeout)
  originStreetNumber     String? @map("origin_street_number")
  originRoute            String? @map("origin_route")
  originCity             String? @map("origin_city")
  originCounty           String? @map("origin_county")
  originState            String? @map("origin_state")
  originZip              String? @map("origin_zip")
  originCountry          String? @map("origin_country")
  originFormatted        String? @map("origin_formatted_address")
  originLat              Float?  @map("origin_lat")
  originLng              Float?  @map("origin_lng")
  originPlaceId          String? @map("origin_place_id")
  originVerification     String? @map("origin_verification_status")
  originValidationReason String? @map("origin_validation_reason")
  destStreetNumber       String? @map("dest_street_number")
  destRoute              String? @map("dest_route")
  destCity               String? @map("dest_city")
  destCounty             String? @map("dest_county")
  destState              String? @map("dest_state")
  destZip                String? @map("dest_zip")
  destCountry            String? @map("dest_country")
  destFormatted          String? @map("dest_formatted_address")
  destLat                Float?  @map("dest_lat")
  destLng                Float?  @map("dest_lng")
  destPlaceId            String? @map("dest_place_id")
  destVerification       String? @map("dest_verification_status")
  destValidationReason   String? @map("dest_validation_reason")

  // ── Move details (owner spec 2026-07-12) — structured inventory of the job.
  //    Nullable; collected on the booking form (future) or entered by staff. ──
  bedrooms           Int?     @map("bedrooms")
  estimatedCubicFeet Int?     @map("estimated_cubic_feet")
  estimatedWeightLbs Int?     @map("estimated_weight_lbs")
  numBoxes           Int?     @map("num_boxes")
  needsPacking       Boolean? @map("needs_packing")
  needsUnpacking     Boolean? @map("needs_unpacking")
  needsAssembly      Boolean? @map("needs_assembly")
  needsDisassembly   Boolean? @map("needs_disassembly")
  needsStorage       Boolean? @map("needs_storage")
  hasPiano           Boolean? @map("has_piano")
  hasSafe            Boolean? @map("has_safe")
  hasPoolTable       Boolean? @map("has_pool_table")
  hasAppliances      Boolean? @map("has_appliances")
  specialtyItems     String?  @map("specialty_items")

  // ── Truck operations (extends the customer-provided truck fields above) ──
  truckReservationNumber String? @map("truck_reservation_number")
  truckPickupTime        String? @map("truck_pickup_time")
  truckReturnAddress     String? @map("truck_return_address")
  driverName             String? @map("driver_name")
  driverPhone            String? @map("driver_phone")
  driverLicense          String? @map("driver_license")
  truckFuelPolicy        String? @map("truck_fuel_policy")
  additionalTruckFees    Int?    @map("additional_truck_fees") // cents

  // ── Itemized fees (cents) — base/travel/truck add-on/discount live above.
  //    Nullable so existing bookings stay null; a professional invoice reads them. ──
  stairFee       Int? @map("stair_fee")
  longCarryFee   Int? @map("long_carry_fee")
  heavyItemFee   Int? @map("heavy_item_fee")
  packingFee     Int? @map("packing_fee")
  assemblyFee    Int? @map("assembly_fee")
  disassemblyFee Int? @map("disassembly_fee")
  taxAmount      Int? @map("tax_amount")
  processingFee  Int? @map("processing_fee")

  // ── Late Arrival & Delay Policy (owner spec 2026-07-12) ───────────────────
  //    Complimentary 30-min grace from crew arrival, then $50 per additional
  //    30-min block. The math lives in src/lib/waiting-time.ts (single source).
  //    The fee is COLLECTED ON MOVE DAY like the travel fee / truck add-on — it
  //    is NEVER added to the $49 Stripe deposit and never auto-charged.
  //    Crew log these four timestamps by tapping the Discord job-card buttons.
  crewArrivedAt       DateTime? @map("crew_arrived_at")
  customerReadyAt     DateTime? @map("customer_ready_at")
  waitingStartedAt    DateTime? @map("waiting_started_at")
  waitingEndedAt      DateTime? @map("waiting_ended_at")
  //    waitingMinutes / waitingFee are DERIVED (waiting-time.ts) and persisted
  //    at waiting-end so the receipt/report is a stable record. waitingFeeOverride
  //    (cents, nullable) lets staff hand-set the charge; waived zeroes it out.
  waitingMinutes      Int?      @map("waiting_minutes")
  waitingFee          Int?      @map("waiting_fee") // cents; derived unless overridden
  waitingFeeOverride  Int?      @map("waiting_fee_override") // cents; staff manual override
  waitingFeeWaived    Boolean   @default(false) @map("waiting_fee_waived")
  waitingWaiverReason String?   @map("waiting_waiver_reason")
  waitingFeeCollected Boolean   @default(false) @map("waiting_fee_collected")

  // ── Internal operations (staff-entered via the admin edit panel) ──
  arrivalWindow      String? @map("arrival_window") // e.g. "8:00–10:00 AM"
  assignedDispatcher String? @map("assigned_dispatcher")
  dispatcherNotes    String? @map("dispatcher_notes")
  crewNotes          String? @map("crew_notes")
  driverNotes        String? @map("driver_notes")
  officeNotes        String? @map("office_notes")
  schedulingNotes    String? @map("scheduling_notes")
  travelNotes        String? @map("travel_notes")
  problemFlags       String? @map("problem_flags")
  outstandingTasks   String? @map("outstanding_tasks")
  completionProgress Int?    @map("completion_progress") // 0–100

  // Moving Service Agreement (legal acceptance record)
  agreementAccepted   Boolean   @default(false) @map("agreement_accepted")
  agreementVersion    String?   @map("agreement_version")
  agreementAcceptedAt DateTime? @map("agreement_accepted_at")
  agreementName       String?   @map("agreement_name") // printed name typed by the customer
  agreementSignature  String?   @map("agreement_signature") // optional typed signature

  // Metadata
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  referrer  String?

  // ── Marketing attribution (Phase 2) — pushed to the marketing-tracker funnel
  //    on payment so booking revenue is attributed to its source / found-us. ──
  source  String? // QR src / tracking code carried by the booking URL
  foundUs String? @map("found_us") // "Where did you find us?" self-report

  // ── Job completion (Phase 3) — set when the booking transitions to COMPLETED;
  //    the anchor time for the post-move follow-up sequence. ──
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer      Customer         @relation(fields: [customerId], references: [id])
  payments      Payment[]
  job           Job?
  files         File[]
  notifications Notification[]
  receipt       Receipt?
  auditLogs     AuditLog[]
  review        Review?
  followUps     FollowUpLedger[]
  expenses      Expense[] // job-linked expenses (admin OS) — reduce this job's profit

  @@index([status])
  @@index([customerId])
  @@index([confirmedDate])
  @@index([customerToken])
  @@map("bookings")
}

// ── Email outbox (src/outbox). Self-contained: bookingId is a plain reference
//    (no FK) so this table is decoupled from the Booking model. The unique
//    idempotency_key (bookingId::EVENT) + ON CONFLICT DO NOTHING is what makes
//    event creation exactly-once. ──
model EmailJob {
  id             String   @id @default(uuid())
  bookingId      String   @map("booking_id")
  eventType      String   @map("event_type")
  idempotencyKey String   @unique @map("idempotency_key") // `${bookingId}::${EVENT}`
  payload        Json
  status         String   @default("pending") // pending | processing | sent | failed
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5) @map("max_attempts")
  lastError      String?  @map("last_error")
  nextAttemptAt  DateTime @default(now()) @map("next_attempt_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt])
  @@index([bookingId])
  @@map("email_jobs")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @map("booking_id")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @unique @map("stripe_charge_id")
  amount                Int // in cents
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  // Internal checkout tests (owner-flagged; mirrors Stripe metadata.internal_test).
  // EXCLUDED from every revenue aggregate/report. Never affects payment status.
  isInternalTest        Boolean       @default(false) @map("is_internal_test")
  description           String?
  receiptUrl            String?       @map("receipt_url")
  metadata              Json?
  // ── Refund + dispute tracking (additive; money truth stays in `status`).
  //    Cumulative refunded cents (monotonic); dispute id + raw Stripe status. ──
  refundedAmountCents   Int?          @map("refunded_amount_cents")
  stripeRefundId        String?       @map("stripe_refund_id")
  stripeDisputeId       String?       @map("stripe_dispute_id")
  disputeStatus         String?       @map("dispute_status")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Job {
  id           String    @id @default(cuid())
  bookingId    String    @unique @map("booking_id")
  status       JobStatus @default(SCHEDULED)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  durationMins Int?      @map("duration_mins")
  crewNotes    String?   @map("crew_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  booking Booking   @relation(fields: [bookingId], references: [id])
  crew    JobCrew[]
  files   File[]

  @@index([status])
  @@map("jobs")
}

model JobCrew {
  id         String   @id @default(cuid())
  jobId      String   @map("job_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // ── Payroll & time tracking (admin OS, owner spec 2026-07-13) — all nullable/
  //    defaulted so existing crew rows read cleanly. amountOwed is DERIVED in
  //    src/lib/profit.ts (never stored): flatPay if set, else payRate*actualHours,
  //    plus tips + bonus - deductions. payRate here overrides the User default. ──
  crewLeader     Boolean        @default(false) @map("crew_leader")
  scheduledHours Float?         @map("scheduled_hours")
  actualHours    Float?         @map("actual_hours")
  clockIn        DateTime?      @map("clock_in")
  clockOut       DateTime?      @map("clock_out")
  breakMinutes   Int?           @map("break_minutes")
  payRate        Int?           @map("pay_rate") // cents/hour; null => User.payRate
  flatPay        Int?           @map("flat_pay") // cents; overrides hourly when set
  tips           Int? // cents
  bonus          Int? // cents
  deductions     Int? // cents
  payMethod      PaymentMethod? @map("pay_method")
  payStatus      CrewPayStatus  @default(SCHEDULED) @map("pay_status")
  paidAt         DateTime?      @map("paid_at")
  payNotes       String?        @map("pay_notes")

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@map("job_crew")
}

model Availability {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  isDayOff  Boolean  @default(false) @map("is_day_off")
  startTime String?  @map("start_time") // "08:00"
  endTime   String?  @map("end_time") // "18:00"
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@map("availability")
}

/// Admin-controlled blocked dates — no jobs scheduled on these days.
model DayBlock {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  blocked   Boolean  @default(true)
  blockedBy String?  @map("blocked_by")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("day_blocks")
}

model File {
  id            String   @id @default(cuid())
  bookingId     String?  @map("booking_id")
  jobId         String?  @map("job_id")
  type          FileType
  cloudinaryId  String   @unique @map("cloudinary_id")
  cloudinaryUrl String   @map("cloudinary_url")
  filename      String
  mimeType      String   @map("mime_type")
  sizeBytes     Int      @map("size_bytes")
  uploadedBy    String?  @map("uploaded_by") // user ID or "customer"
  createdAt     DateTime @default(now()) @map("created_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  job     Job?     @relation(fields: [jobId], references: [id])

  @@index([bookingId])
  @@index([jobId])
  @@map("files")
}

model Receipt {
  id            String    @id @default(cuid())
  bookingId     String    @unique @map("booking_id")
  cloudinaryId  String?   @map("cloudinary_id")
  cloudinaryUrl String?   @map("cloudinary_url")
  sentAt        DateTime? @map("sent_at")
  sentTo        String?   @map("sent_to")
  createdAt     DateTime  @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("receipts")
}

model Notification {
  id        String              @id @default(cuid())
  bookingId String?             @map("booking_id")
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  recipient String // email / phone / discord channel
  subject   String?
  template  String // template name
  payload   Json // template data
  bullJobId String?             @map("bull_job_id")
  sentAt    DateTime?           @map("sent_at")
  error     String?
  retries   Int                 @default(0)
  // Email open tracking (1x1 tracking-pixel). openToken is embedded in the
  // sent email; GET /api/email/open stamps openedAt + isOpened on first load
  // and bumps openCount on every load. Only meaningful for EMAIL channel.
  openToken String?             @unique @map("open_token")
  openedAt  DateTime?           @map("opened_at")
  isOpened  Boolean             @default(false) @map("is_opened")
  openCount Int                 @default(0) @map("open_count")
  createdAt DateTime            @default(now()) @map("created_at")

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("notifications")
}

model WebhookLog {
  id          String    @id @default(cuid())
  source      String // "stripe" | "discord"
  eventType   String    @map("event_type")
  eventId     String?   @unique @map("event_id") // idempotency key
  payload     Json
  status      String // "processed" | "failed" | "duplicate"
  error       String?
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([source])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_logs")
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  userId    String?     @map("user_id") // null = system
  bookingId String?     @map("booking_id")
  details   Json?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  result    Json?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum ManualEventType {
  QUOTE // price quote given
  VISIT // went out in person
  ONSITE // customer wants the quote on-site
  NOBOOK // customer chose not to book
  JOBACCEPT // customer gave a verbal yes
  FOLLOWUP // needs a follow-up / call back
}

/// Field events logged manually by the crew from Discord (/quote, /visit, /onsite,
/// /nobook, /jobaccept, /followup). First-party ground truth from the field to
/// complement the automated booking + payment data above. Standalone by design —
/// these capture leads who never entered the booking flow.
model ManualEvent {
  id           String          @id @default(cuid())
  eventType    ManualEventType @map("event_type")
  customerName String?         @map("customer_name")
  zip          String?
  jobType      String?         @map("job_type")
  notes        String?
  loggedBy     String?         @map("logged_by") // Discord user tag who entered it
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([eventType])
  @@index([zip])
  @@index([createdAt])
  @@map("manual_events")
}

enum TaskOwner {
  DIEGO
  SEBASTIAN
}

enum TaskStatus {
  OPEN
  DONE
}

/// Owner task board (#owner-tasks). Manually-created tasks for Diego & Sebastian,
/// ranked by importance (5 = highest), then due date, then due time. Created from
/// Discord slash commands (/task_add, /task_list, …).
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  importance  Int        @default(3) // 1–5, 5 = highest priority
  owner       TaskOwner
  dueDate     DateTime   @map("due_date") // calendar date, stored at UTC midnight
  dueTime     String?    @map("due_time") // optional, normalized "HH:MM" 24h for sorting
  status      TaskStatus @default(OPEN)
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([owner])
  @@index([dueDate])
  @@map("tasks")
}

/// Exactly-once ledger for post-job customer follow-ups (Phase 3). A row is
/// written BEFORE the message is sent, so the @@unique([bookingId, type]) is the
/// hard anti-spam guarantee: a BullMQ retry, a double completion trigger, or a
/// re-enqueue can never send the same follow-up twice. `referral-ask` is shared
/// by the positive-review path and the day-5 fallback, so the customer gets at
/// most ONE referral ask per booking.
model FollowUpLedger {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  type      String // review-request | review-reminder | repeat-reminder | referral-ask
  channel   String   @default("both") // sms | email | both
  status    String   @default("sent") // sent | failed | skipped
  error     String?
  sentAt    DateTime @default(now()) @map("sent_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, type])
  @@index([bookingId])
  @@map("followup_ledger")
}

/// Customer review of a completed move (Phase 3). Recorded by staff (admin UI /
/// Discord command) or the customer portal — there is no Google review webhook,
/// so the rating is captured first-party. A positive review (rating >= 4) fires
/// exactly one referral ask and suppresses the 48h review reminder.
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique @map("booking_id")
  rating     Int // 1..5
  isPositive Boolean  @default(false) @map("is_positive")
  source     String   @default("admin") // admin | discord | customer-portal
  comment    String?
  leftAt     DateTime @default(now()) @map("left_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("reviews")
}

// ============================================================
// ADMIN OPERATING SYSTEM — the money spine (owner spec 2026-07-13)
// Rule: every dollar connects to a JOB (Expense.bookingId set), an OWNER
// transaction (OwnerTransaction), or a GENERAL business expense (Expense with
// no bookingId). This keeps revenue, real profit, worker pay, and personal
// money from ever mixing together.
// ============================================================

/// A cost the business paid. bookingId set => a JOB expense that reduces THAT
/// job's profit. bookingId null => a GENERAL business expense (Railway, ads,
/// insurance…) that reduces monthly business profit without touching one job.
/// Receipt is stored as the Cloudinary URL from /api/files/upload (no File FK,
/// mirroring EmailJob's plain-reference decoupling). createdBy is denormalized
/// (id + name) like AuditLog details — no relation churn on User.
model Expense {
  id              String          @id @default(cuid())
  amount          Int // cents
  incurredOn      DateTime        @map("incurred_on")
  category        ExpenseCategory
  vendor          String?
  paymentMethod   PaymentMethod?  @map("payment_method")
  paidBy          String?         @map("paid_by") // owner name / worker / "business"
  bookingId       String?         @map("booking_id") // null = general business expense
  purpose         String? // business purpose
  receiptUrl      String?         @map("receipt_url")
  receiptPublicId String?         @map("receipt_public_id")
  reimbursable    Boolean         @default(false)
  status          ExpenseStatus   @default(SUBMITTED)
  notes           String?
  createdById     String?         @map("created_by_id")
  createdByName   String?         @map("created_by_name")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([category])
  @@index([status])
  @@index([incurredOn])
  @@map("expenses")
}

/// Diego / Sebastian owner money — kept OUT of business expenses on purpose so
/// personal cash never contaminates job profit. Reuses TaskOwner (DIEGO |
/// SEBASTIAN). bookingId is an optional plain reference (e.g. a distribution
/// tied to a specific job); no FK by design.
model OwnerTransaction {
  id              String               @id @default(cuid())
  owner           TaskOwner
  amount          Int // cents
  type            OwnerTransactionType
  occurredOn      DateTime             @map("occurred_on")
  paymentMethod   PaymentMethod?       @map("payment_method")
  explanation     String?
  receiptUrl      String?              @map("receipt_url")
  receiptPublicId String?              @map("receipt_public_id")
  approvalStatus  ApprovalStatus       @default(PENDING) @map("approval_status")
  bookingId       String?              @map("booking_id") // optional plain reference
  createdById     String?              @map("created_by_id")
  createdByName   String?              @map("created_by_name")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([owner])
  @@index([type])
  @@index([occurredOn])
  @@map("owner_transactions")
}

/// A sales lead in the pipeline (NEW -> CONTACTED -> QUOTE_SENT -> FOLLOW_UP ->
/// BOOKED | LOST). Standalone from ManualEvent (field-log) and Booking — this is
/// the funnel + marketing-source attribution. convertedBookingId is a plain
/// reference set when a lead becomes a real booking (revenue-by-source report).
model Lead {
  id                 String          @id @default(cuid())
  name               String
  phone              String?
  email              String?
  source             LeadSource      @default(OTHER)
  status             LeadStatus      @default(NEW)
  lostReason         LeadLostReason? @map("lost_reason")
  estimatedValue     Int?            @map("estimated_value") // cents
  jobType            String?         @map("job_type")
  moveDate           DateTime?       @map("move_date")
  zip                String?
  notes              String?
  assignedTo         String?         @map("assigned_to")
  convertedBookingId String?         @map("converted_booking_id") // plain reference

  // ── Ingestion + attribution (createOrUpdateLead, 2026-07-15) — all nullable,
  //    additive. Populated by the shared lead-ingestion service from the contact
  //    form, coupon popup, "not sure" bookings, and the marketing tracker. ──
  message        String?
  originCity     String?   @map("origin_city")
  destCity       String?   @map("dest_city")
  utmSource      String?   @map("utm_source")
  utmMedium      String?   @map("utm_medium")
  utmCampaign    String?   @map("utm_campaign")
  utmContent     String?   @map("utm_content")
  utmTerm        String?   @map("utm_term")
  landingPage    String?   @map("landing_page")
  referrer       String?
  promoCode      String?   @map("promo_code")
  lastActivityAt DateTime? @map("last_activity_at")
  contactedAt    DateTime? @map("contacted_at")
  quotedAt       DateTime? @map("quoted_at")
  bookedAt       DateTime? @map("booked_at")
  lostAt         DateTime? @map("lost_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([email])
  @@index([phone])
  @@index([lastActivityAt])
  @@map("leads")
}

/// Action Center reminder (increment 2, owner spec 2026-07-13). Rows are
/// created by DETERMINISTIC rules in src/lib/reminder-rules.ts (no AI) via the
/// sync in src/lib/reminder-sync.ts. dedupeKey (rule + entity) is the anti-spam
/// guarantee: a rule re-run updates the existing row instead of duplicating it.
/// System reminders auto-RESOLVE when the underlying condition clears and can
/// REOPEN if it returns; DISMISSED is a human decision the scanner respects.
/// History is never hard-deleted through owner actions.
model Reminder {
  id               String           @id @default(cuid())
  reminderType     String           @map("reminder_type") // stable rule id, e.g. "job-24h-no-crew"
  category         ReminderCategory
  title            String
  description      String
  severity         ReminderSeverity
  status           ReminderStatus   @default(OPEN)
  sourceEntityType String?          @map("source_entity_type") // booking | expense | lead | customer | crew
  sourceEntityId   String?          @map("source_entity_id")
  sourceUrl        String?          @map("source_url") // admin deep link
  dedupeKey        String           @unique @map("dedupe_key")
  dueAt            DateTime?        @map("due_at")
  snoozedUntil     DateTime?        @map("snoozed_until")
  assignedOwner    TaskOwner?       @map("assigned_owner")
  createdBy        String           @default("system") @map("created_by")
  internalNote     String?          @map("internal_note") // owner note; preserved across rule re-runs
  resolutionNote   String?          @map("resolution_note")
  metadata         Json?
  acknowledgedAt   DateTime?        @map("acknowledged_at")
  startedAt        DateTime?        @map("started_at")
  resolvedAt       DateTime?        @map("resolved_at")
  dismissedAt      DateTime?        @map("dismissed_at")

  // ── Lifecycle & accountability (increment 2.1) — all nullable/defaulted ──
  //    entityFingerprint = deterministic hash of the candidate's material state
  //    (severity + dueAt + description). A dismissal with OCCURRENCE or
  //    UNTIL_ENTITY_CHANGES scope reopens when it changes. dismissalScope drives
  //    whether a dismissed reminder can ever return.
  assignedAt        DateTime?       @map("assigned_at")
  assignedByName    String?         @map("assigned_by_name")
  claimedById       String?         @map("claimed_by_id")
  claimedByName     String?         @map("claimed_by_name")
  claimedAt         DateTime?       @map("claimed_at")
  completedById     String?         @map("completed_by_id")
  completedByName   String?         @map("completed_by_name")
  dismissalScope    DismissalScope? @map("dismissal_scope")
  dismissedById     String?         @map("dismissed_by_id")
  dismissedByName   String?         @map("dismissed_by_name")
  entityFingerprint String?         @map("entity_fingerprint")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([dueAt])
  @@index([assignedOwner])
  @@index([sourceEntityType, sourceEntityId])
  @@map("reminders")
}

/// Reminder scan run metadata (increment 2.1). Every full Action Center scan
/// records a row so the UI can show the last successful / last failed scan, the
/// current running state, and per-scan counts. A Postgres advisory lock (see
/// src/lib/scan-lock.ts) prevents two scans from overlapping; a RUNNING row
/// older than the stale timeout is treated as crashed.
model ScanRun {
  id                String      @id @default(cuid())
  status            ScanStatus  @default(RUNNING)
  trigger           ScanTrigger
  startedAt         DateTime    @default(now()) @map("started_at")
  completedAt       DateTime?   @map("completed_at")
  durationMs        Int?        @map("duration_ms")
  triggeredById     String?     @map("triggered_by_id")
  triggeredByName   String?     @map("triggered_by_name")
  rulesEvaluated    Int?        @map("rules_evaluated")
  entitiesEvaluated Int?        @map("entities_evaluated")
  remindersCreated  Int?        @map("reminders_created")
  remindersUpdated  Int?        @map("reminders_updated")
  remindersReopened Int?        @map("reminders_reopened")
  remindersResolved Int?        @map("reminders_resolved")
  remindersSkipped  Int?        @map("reminders_skipped")
  errorCount        Int         @default(0) @map("error_count")
  errorSummary      String?     @map("error_summary") // sanitized — never secrets/PII
  worker            String? // process/service identifier when known

  @@index([status])
  @@index([startedAt])
  @@map("scan_runs")
}

/// Ideas & Roadmap item (increment 2). Structured product/business planning —
/// not a notes page. seedKey makes the preloaded gap items idempotent (the seed
/// endpoint skips keys that already exist). comments is an append-only JSON
/// array of {by, at, text}. No hard delete — REJECTED/ARCHIVED instead.
model RoadmapItem {
  id              String          @id @default(cuid())
  seedKey         String?         @unique @map("seed_key")
  title           String
  summary         String?
  problem         String? // business problem
  solution        String? // proposed solution
  benefit         String? // expected benefit
  risks           String?
  priority        RoadmapPriority @default(MEDIUM)
  status          RoadmapStatus   @default(IDEA)
  category        RoadmapCategory @default(OTHER)
  impact          Int? // 1-5
  effort          Int? // 1-5
  dependencies    String?
  blockers        String?
  assignedOwner   TaskOwner?      @map("assigned_owner")
  targetIncrement String?         @map("target_increment")
  notes           String?
  comments        Json? // [{by, at, text}]
  rejectionReason String?         @map("rejection_reason")
  completedAt     DateTime?       @map("completed_at")
  createdBy       String?         @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([priority])
  @@map("roadmap_items")
}

/// Single-row business configuration (ownership split + cash reserves). The
/// ownership split NEVER means all cash is distributable — the Owner Money page
/// subtracts upcoming worker pay + bills + tax/emergency reserves first.
model BusinessConfig {
  id                    String   @id @default("singleton")
  diegoSplitPercent     Int      @default(50) @map("diego_split_percent")
  sebastianSplitPercent Int      @default(50) @map("sebastian_split_percent")
  taxReservePercent     Int      @default(25) @map("tax_reserve_percent") // % of profit held for taxes
  emergencyReserveCents Int      @default(0) @map("emergency_reserve_cents")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("business_config")
}

// ═══════════════════════════════════════════════════════════════════════════
//  EMAIL LIFECYCLE (owner spec 2026-07-20) — suppression, send ledger, events.
//
//  These three models are the release-blocker foundation the email system was
//  missing: there was no way to record an unsubscribe, no way to act on a hard
//  bounce or spam complaint, no durable per-send record, and no idempotency
//  key — so a worker retry after a successful provider call could resend.
//
//  All three are ADDITIVE. Nothing existing reads or writes them yet, so the
//  migration is safe to apply ahead of the code that uses it.
// ═══════════════════════════════════════════════════════════════════════════

/// Why an address may no longer receive email. Ordered loosely by severity.
/// UNSUBSCRIBED blocks PROMOTIONAL only; every other reason blocks ALL mail
/// (a hard-bouncing or complaining address must not be written to at all).
enum SuppressionReason {
  UNSUBSCRIBED
  HARD_BOUNCE
  SPAM_COMPLAINT
  INVALID_ADDRESS
  ADMIN_BLOCK
  PROVIDER_REJECTED
}

/// The ONE global do-not-send list, keyed on the lowercased address so it works
/// for Customers, Leads, and anyone Leadtracking (SendGrid) knows about but this
/// database does not. `scope` records whether the block is promotional-only.
model EmailSuppression {
  id        String            @id @default(cuid())
  /// Always stored lowercased + trimmed. Unique = the list is idempotent.
  email     String            @unique
  reason    SuppressionReason
  /// 'promotional' (unsubscribe) | 'all' (bounce/complaint/invalid/admin).
  scope     String            @default("all")
  /// Where the signal came from: 'unsubscribe-link' | 'resend-webhook' |
  /// 'leadtracking' | 'admin' | 'sms-stop'.
  source    String?
  /// Free-text provider detail (bounce sub-type, complaint feedback id, …).
  detail    String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([reason])
  @@index([createdAt])
  @@map("email_suppressions")
}

/// One row per attempted send. Claimed BEFORE the provider call, so a crash or
/// retry after a successful send finds the row and refuses to send again.
/// `idempotencyKey` is the exactly-once guarantee (see src/lib/email-guard.ts).
model EmailSend {
  id             String    @id @default(cuid())
  /// recipient + template + journey + qualifying-event id + template version.
  idempotencyKey String    @unique @map("idempotency_key")
  email          String
  template       String
  /// 'transactional' | 'promotional' — drives suppression scope + frequency caps.
  emailClass     String    @map("email_class")
  /// Lifecycle journey this send belongs to, when it is part of one.
  journey        String?
  bookingId      String?   @map("booking_id")
  leadId         String?   @map("lead_id")
  campaign       String?
  /// 'claimed' | 'sent' | 'blocked' | 'failed'
  status         String    @default("claimed")
  /// Why a 'blocked' row was blocked (suppression reason, cap, stale state, …).
  blockedReason  String?   @map("blocked_reason")
  /// Resend message id, once accepted.
  providerId     String?   @map("provider_id")
  error          String?
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  events EmailEvent[]

  @@index([email])
  @@index([status])
  @@index([journey])
  @@index([bookingId])
  @@index([leadId])
  @@index([createdAt])
  @@map("email_sends")
}

/// Provider + first-party engagement events. `providerEventId` is unique so a
/// duplicate webhook delivery is a no-op (providers retry aggressively).
model EmailEvent {
  id              String   @id @default(cuid())
  /// Provider event id, or a synthesized stable id for first-party events.
  providerEventId String   @unique @map("provider_event_id")
  emailSendId     String?  @map("email_send_id")
  email           String
  /// 'delivered' | 'bounced' | 'complained' | 'opened' | 'clicked' |
  /// 'delivery_delayed' | 'unsubscribed'
  type            String
  /// Raw provider payload excerpt for triage (never PII beyond the address).
  detail          String?
  occurredAt      DateTime @default(now()) @map("occurred_at")
  createdAt       DateTime @default(now()) @map("created_at")

  emailSend EmailSend? @relation(fields: [emailSendId], references: [id])

  @@index([email])
  @@index([type])
  @@index([emailSendId])
  @@index([occurredAt])
  @@map("email_events")
}
